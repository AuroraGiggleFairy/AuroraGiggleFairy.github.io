<!--Old Lanterns and regular ones combined into one Variant Helper-->
	<set xpath="/blocks/block[@name='lanternOld_01_Player']/property[@name='CanPickup']/@param1">lanternDecorLightBlockVariantHelper</set>

<!--Editing the existing Lantern Variant Block to include new player flashlights and the old lanterns.-->
<append xpath="/blocks/block[@name='lanternDecorLightBlockVariantHelper']/property[@name='PlaceAltBlockValue']/@value">,lanternOld_01_Player,lanternOld_02_Player,lanternOld_03_Player,lanternOld_04_Player,flashlightCornerDecorBlue_player,flashlightCornerDecorGreen_player,flashlightCornerDecorOrange_player,flashlightCornerDecorRed_player,flashlightCornerDecorWhite_player,flashlightCornerDecorYellow_player,flashlightDecorBlue_player,flashlightDecorGreen_player,flashlightDecorOrange_player,flashlightDecorRed_player,flashlightDecorWhite_player,flashlightDecorYellow_player,flashlightSideCenteredDecorBlue_player,flashlightSideCenteredDecorGreen_player,flashlightSideCenteredDecorOrange_player,flashlightSideCenteredDecorRed_player,flashlightSideCenteredDecorWhite_player,flashlightSideCenteredDecorYellow_player</append>







<!--Pick up lanterns and such-->
		<append xpath="/blocks/block[@name='lanternDecorLightWhite']">
			<property name="CanPickup" value="true" param1="lanternDecorLightBlockVariantHelper"/>
			<property name="TakeDelay" value="2"/>		
			<property name="Class" value=""/>
			<property name="Material" value="Mmetal_thin"/>
		</append>
		<append xpath="/blocks/block[@name='burningBarrel']"> 
			<property name="CanPickup" value="true" param1="burningBarrelPlayer"/>
			<property name="TakeDelay" value="2"/>		
			<property name="Class" value=""/>
		</append>	
		<append xpath="/blocks/block[@name='decoPumpkinJackOLantern']"> 
			<property name="CanPickup" value="true" param1="decoPumpkinJackOLantern"/>
			<property name="TakeDelay" value="2"/>		
			<property name="Class" value=""/>
		</append>				
		<append xpath="/blocks/block[starts-with(@name,'flashlightDecor')]">
			<property name="CanPickup" value="true" param1="lanternDecorLightBlockVariantHelper"/>
			<property name="TakeDelay" value="2"/>	
			<property name="Class" value=""/>
		</append>
		<append xpath="/blocks/block[starts-with(@name,'flashlightSideCenteredDecor')]">
			<property name="CanPickup" value="true" param1="lanternDecorLightBlockVariantHelper"/>
			<property name="TakeDelay" value="2"/>	
