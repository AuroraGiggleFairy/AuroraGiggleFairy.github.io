			<property name="HandleFace" value="Bottom"/>
			<property name="IgnoreLightsOff" value="true"/>
			<property name="SortOrder1" value="B202"/>
			<property name="SortOrder2" value="1302"/>
			<property name="FilterTags" value="MC_building,SC_lighting,A21_NEW"/>	
