			<set xpath="/windows/window[@name='windowCompass']//rect[@name='extraStats2']/sprite[@name='lootStageIcon']/@depth">10</set>
			<set xpath="/windows/window[@name='windowCompass']//rect[@name='extraStats2']/sprite[@name='inventorySlotsIcon']/@depth">10</set>
			<set xpath="/windows/window[@name='windowCompass']//rect[@name='extraStats2']/sprite[@name='inventorySlotsIcon']/@pos">190,-15</set>
			<set xpath="/windows/window[@name='windowCompass']//rect[@name='extraStats2']/label[@name='inventorySlots']/@pos">222,-17</set>
		</if>
	</conditional>
</zzzAGF-Compatibilities>
