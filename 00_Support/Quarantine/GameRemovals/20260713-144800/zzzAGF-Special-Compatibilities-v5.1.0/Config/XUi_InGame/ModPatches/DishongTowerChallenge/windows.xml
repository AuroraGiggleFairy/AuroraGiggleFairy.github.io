			<remove xpath="/windows/window[@name='windowCompass']/rect[@name='Location']/grid"/>
			<append xpath="/windows/window[@name='windowCompass']/rect[@name='Location']">
				<rect name="statsExtra1" controller="PlayerStats, EnhancedAGF" pos="0,6" width="250" height="76" pivot="center">
					<sprite depth="2" name="background" color="0,0,0,210" type="sliced" sprite="ui_game_header_fill" foregroundlayer="true"/>
					<sprite depth="2" name="coldIcon" pos="18,-18" width="19" height="19" pivot="center" justify="center" sprite="ui_game_symbol_cold" color="201, 201, 201" foregroundlayer="true" tooltip_key="statHypothermalResist"/>
					<label depth="15" name="coldResist" pos="48,-21" width="56" height="20" pivot="center" justify="center" text="[00ffff]{PlayerColdResist}" font_size="18" tooltip_key="statHypothermalResist"/>
					<sprite depth="2" name="tempIcon" pos="106,-18" width="19" height="19" pivot="center" justify="center" sprite="ui_game_symbol_temperature" color="201, 201, 201" foregroundlayer="true" tooltip_key="xuiBuffStatCoreTemp"/>
					<label depth="15" name="coreTemp" pos="136,-21" width="56" height="20" pivot="center" justify="center" text="[DECEA3]{PlayerCoreTemp}" font_size="18" tooltip_key="xuiBuffStatCoreTemp"/>
					<sprite depth="2" name="hotIcon" pos="190,-15" width="19" height="19" pivot="center" justify="center" sprite="ui_game_symbol_hot" color="201, 201, 201" foregroundlayer="true" tooltip_key="statHyperthermalResist"/>
