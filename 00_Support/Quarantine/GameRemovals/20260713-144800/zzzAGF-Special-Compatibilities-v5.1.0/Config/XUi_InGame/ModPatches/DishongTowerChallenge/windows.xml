<zzzAGF-Compatibilities>
	<!-- DishongTowerChallenge -->
	<conditional>
		<if cond="mod_loaded('AGF-HUDPlus-1Main') and mod_loaded('AGF-HUDPlus-BMCounter')">
			<append xpath="/windows/window[@name='windowCompass']">
				<rect name="floorLevel" controller="PlayerStats, EnhancedAGF" pos="70,-87" width="380">
					<label depth="6" name="TextContent" pos="0,0" font_size="60" color="[white]" justify="center" text="{PlayerFloorLevelDTC}" height="35" width="380" style="outline" effect="outline" effect_distance="1,1" effect_color="[black]"/>
					<!--{Hard Coded to read Localization}-->
				</rect>
			</append>
			<set xpath="/windows/window[@name='windowTargetBar']/rect[1]/@pos">-199,-142</set>
			<set xpath="/windows/window[@name='windowTargetBar']/rect[2]/@pos">-267,-142</set>
		</if>
		<if cond="mod_loaded('AGF-HUDPlus-1Main')">
			<append xpath="/windows/window[@name='windowCompass']">
				<rect name="floorLevel" controller="PlayerStats, EnhancedAGF" pos="70,-53" width="380">
					<label depth="6" name="TextContent" pos="0,0" font_size="60" color="[white]" justify="center" text="{PlayerFloorLevelDTC}" height="35" width="380" style="outline" effect="outline" effect_distance="1,1" effect_color="[black]"/>
					<!--{Hard Coded to read Localization}-->
				</rect>
			</append>
		</if>
	</conditional>
	<conditional>
		<if cond="mod_loaded('AGF-HUDPlus-1Main') and mod_loaded('AGF-NoEAC-EnhancedAGF')">
			<remove xpath="/windows/window[@name='windowCompass']/rect[@name='dayTimeTemp']/label[6]"/>
			<remove xpath="/windows/window[@name='windowCompass']/rect[@name='dayTimeTemp']/label[5]"/>
			<remove xpath="/windows/window[@name='windowCompass']/rect[@name='dayTimeTemp']/conditional"/>
			<set xpath="/windows/window[@name='windowCompass']/rect[@name='dayTimeTemp']/sprite[1]/@height">76</set>
			<set xpath="/windows/window[@name='windowCompass']/rect[@name='dayTimeTemp']/label[1]/@pos">107,-14</set>
			<set xpath="/windows/window[@name='windowCompass']/rect[@name='dayTimeTemp']/label[1]/@height">38</set>
			<set xpath="/windows/window[@name='windowCompass']/rect[@name='dayTimeTemp']/label[1]/@width">80</set>
			<set xpath="/windows/window[@name='windowCompass']/rect[@name='dayTimeTemp']/label[1]/@font_size">26</set>
			<set xpath="/windows/window[@name='windowCompass']/rect[@name='dayTimeTemp']/label[2]/@pos">107,-48</set>
			<set xpath="/windows/window[@name='windowCompass']/rect[@name='dayTimeTemp']/label[2]/@height">38</set>
			<set xpath="/windows/window[@name='windowCompass']/rect[@name='dayTimeTemp']/label[2]/@width">80</set>
			<set xpath="/windows/window[@name='windowCompass']/rect[@name='dayTimeTemp']/label[2]/@font_size">26</set>
			<set xpath="/windows/window[@name='windowCompass']/rect[@name='dayTimeTemp']/label[3]/@pos">187,-14</set>
			<set xpath="/windows/window[@name='windowCompass']/rect[@name='dayTimeTemp']/label[3]/@height">38</set>
			<set xpath="/windows/window[@name='windowCompass']/rect[@name='dayTimeTemp']/label[3]/@width">125</set>
			<set xpath="/windows/window[@name='windowCompass']/rect[@name='dayTimeTemp']/label[3]/@font_size">26</set>
			<set xpath="/windows/window[@name='windowCompass']/rect[@name='dayTimeTemp']/label[4]/@pos">187,-48</set>
			<set xpath="/windows/window[@name='windowCompass']/rect[@name='dayTimeTemp']/label[4]/@height">38</set>
			<set xpath="/windows/window[@name='windowCompass']/rect[@name='dayTimeTemp']/label[4]/@width">125</set>
			<set xpath="/windows/window[@name='windowCompass']/rect[@name='dayTimeTemp']/label[4]/@font_size">26</set>
			<append xpath="/windows/window[@name='windowCompass']/rect[@name='dayTimeTemp']">
				<rect name="nightDay" controller="PlayerStats, EnhancedAGF" pos="14,-9">
					<sprite depth="8" name="Night" color="210,235,52" sprite="ui_game_symbol_twitch_special" width="40" height="40" visible="{PlayerIsNight}" tooltip_key="goZMNight"/>
					<sprite depth="8" name="Day" pos="0,-2" color="230,138,18" sprite="ui_game_symbol_hot" width="40" height="40" visible="{PlayerIsDay}" tooltip_key="goZMDay"/>
				</rect>
			</append>
			<remove xpath="/windows/window[@name='windowCompass']/rect[@name='Location']/sprite"/>
