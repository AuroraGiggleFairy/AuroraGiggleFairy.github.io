<AGF-HUDPlus-Weekday>
	<!--Thanks to DragonTander, we now can easily add days of the week!-->

		<conditional>
			<if cond="mod_loaded('AGF-HUDPlus-1Main')">
				<!--Uses my HUD and IS NOT using the NoDayCount-->
				<set xpath="/windows/window[@name='windowCompass']/rect[@name='dayTimeTemp']/label[@text='[{daycolor}]{day}']/@text">[{daycolor}]{day}, {# localization('daycount_' + day%7)}[-]</set>
			</if>
			<else>
				<!--Using Vanilla HUD-->
				<set xpath="/windows/window[@name='windowCompass']/sprite[3]/label[@depth='2']/@text">{daytitle}: [{daycolor}]{day}, {# localization('daycount_' + day%7)}[-]     {timetitle}: {time}     [{outsidetempcolor}]{outsidetemp}[-]</set>
				<set xpath="/windows/window[@name='windowCompass']/sprite[4]/label[@depth='2']/@text">{daytitle}: [{daycolor}]{day}, {# localization('daycount_' + day%7)}[-]     {timetitle}: {time}     [{outsidetempcolor}]{outsidetemp}[-]</set>
			</else>
		</conditional>


</AGF-HUDPlus-Weekday>