		<spawn id="ne01" maxcount="5" respawndelay="1.8" time="Night" entitygroup="EnemyAnimalsDesertNight" /><!-- default 1, 1.8 -->
	</biome>

	<!-- *** SNOW_SPAWNS -->
	<biome name="snow">
		<spawn id="dz01" maxcount="5" respawndelay="0.9" time="Day" entitygroup="ZombiesSnow" notags="downtown" /><!-- default 1, 0.9 -->
		<spawn id="nz04" maxcount="5" respawndelay="1.1" time="Night" entitygroup="ZombiesSnowNight" notags="downtown" /><!-- default 1, 1.1 -->

		<spawn id="dz04" maxcount="5" respawndelay="2.6" time="Day" entitygroup="ZombiesAll" notags="commercial,industrial,downtown" /><!-- default 1, 2.6 -->
		<spawn id="nz01" maxcount="10" respawndelay="1.3" time="Night" entitygroup="ZombiesNight" notags="commercial,industrial,downtown" /><!-- default 2, 1.3 -->

		<spawn id="dz02" maxcount="20" respawndelay="0.09" time="Day" entitygroup="ZombiesAll" tags="commercial,industrial" notags="downtown" /><!-- default 4, 0.09 -->
		<spawn id="nz02" maxcount="20" respawndelay="0.06" time="Night" entitygroup="ZombiesNight" tags="commercial,industrial" notags="downtown" /><!-- default 4, 0.06 -->

