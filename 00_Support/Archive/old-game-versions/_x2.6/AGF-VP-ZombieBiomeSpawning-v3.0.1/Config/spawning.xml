		<spawn id="ae01" maxcount="4" respawndelay="2.6" time="Any" entitygroup="EnemyAnimalsSnow" /><!-- default 1, 2.6 -->
		<spawn id="ne01" maxcount="5" respawndelay="1.6" time="Night" entitygroup="EnemyAnimalsSnowNight" /><!-- default 1, 1.6 -->
	</biome>

	<!-- *** WASTELAND_SPAWNS -->
	<biome name="wasteland">
		<spawn id="dz01" maxcount="5" respawndelay="0.3" time="Day" entitygroup="ZombiesWasteland" notags="commercial,industrial,downtown" /><!-- default 1, 0.3 -->
		<spawn id="dz04" maxcount="5" respawndelay="1.6" time="Day" entitygroup="ZombiesAllWasteland" notags="commercial,industrial,downtown" /><!-- default 1, 1.6 -->
		<spawn id="nz01" maxcount="10" respawndelay="0.003" time="Night" entitygroup="ZombiesWastelandNight" notags="commercial,industrial,downtown" /><!-- default 2, 0.003 -->

		<spawn id="dz02" maxcount="20" respawndelay="0.033" time="Day" entitygroup="ZombiesAllWasteland" tags="commercial,industrial" notags="downtown" /><!-- default 4, 0.033 -->
		<spawn id="nz02" maxcount="20" respawndelay="0.002" time="Night" entitygroup="ZombiesWastelandNight" tags="commercial,industrial" notags="downtown" /><!-- default 4, 0.002 -->

		<spawn id="dz03" maxcount="20" respawndelay="0.0167" time="Day" entitygroup="ZombiesWastelandDowntown" tags="downtown" /><!-- default 4, 0.0167 -->
		<spawn id="nz03" maxcount="20" respawndelay="0.002" time="Night" entitygroup="ZombiesWastelandDowntown" tags="downtown" /><!-- default 4, 0.002 -->

		<spawn id="na01" maxcount="5" respawndelay="3.2" time="Night" entitygroup="WildGameStagNight" /><!-- default 1, 3.2 -->
		<spawn id="ae01" maxcount="5" respawndelay="0.9" time="Any" entitygroup="EnemyAnimalsWasteland" /><!-- default 1, 0.9 -->
		<spawn id="ne01" maxcount="5" respawndelay="0.6" time="Night" entitygroup="EnemyAnimalsWastelandNight" /><!-- default 1, 0.6 -->
	</biome>

</append>




</AGFVanillaPlus-ProgressiveBiomeSpawning>