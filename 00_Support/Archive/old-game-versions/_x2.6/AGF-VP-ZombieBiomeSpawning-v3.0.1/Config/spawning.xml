		<spawn id="dz04" maxcount="5" respawndelay="2.7" time="Day" entitygroup="ZombiesAll" notags="commercial,industrial,downtown" /><!-- default 1, 2.7 -->
		<spawn id="nz01" maxcount="10" respawndelay="2.5" time="Night" entitygroup="ZombiesNight" notags="commercial,industrial,downtown" /><!-- default 2, 2.5 -->

		<spawn id="dz02" maxcount="15" respawndelay="0.2" time="Day" entitygroup="ZombiesAll" tags="commercial,industrial" notags="downtown" /><!-- default 3, 0.2 -->
		<spawn id="nz02" maxcount="15" respawndelay="0.1" time="Night" entitygroup="ZombiesNight" tags="commercial,industrial" notags="downtown" /><!-- default 3, 0.1 -->

		<spawn id="dz03" maxcount="15" respawndelay="0.2" time="Day" entitygroup="ZombiesDowntown" tags="downtown" /><!-- default 3, 0.2 -->
