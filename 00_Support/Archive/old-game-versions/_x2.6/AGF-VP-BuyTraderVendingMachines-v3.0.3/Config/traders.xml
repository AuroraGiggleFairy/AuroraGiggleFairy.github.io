<AGFVanillaPlus-BuyTraderVendingMachines>
	


<!--Trader Stage has to be 100 in order for the machines to show as purchaseable-->
	<append xpath="traders/traderstage_templates">	
		<traderstage_template name="agfTier"> 
			<entry min="100" max="999999" quality="0"/>
		</traderstage_template>	
	</append>
	
	
<!--Just to group the 4 working vending machines-->
	<insertafter xpath="/traders/trader_item_groups/trader_item_group[@name='traderElectrical']">
		<trader_item_group name="AGFVending">
			<item name="cntVendingMachineDrinks_PlayerVariantHelper" />
			<item name="cntVendingMachineSnacksFull_Player" />
		</trader_item_group>
	</insertafter>
	
<!--Placed within all traders-->	
	<append xpath="/traders/trader_item_groups/trader_item_group[@name='traderGeneral']">
		<item group="AGFVending" count="1,2"/>
	</append>




</AGFVanillaPlus-BuyTraderVendingMachines>
