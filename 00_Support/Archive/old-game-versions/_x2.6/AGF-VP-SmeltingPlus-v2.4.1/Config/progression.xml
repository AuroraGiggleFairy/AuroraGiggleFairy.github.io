<AGFVanillaPlus-SmeltingPlus>


	<append xpath="/progression/crafting_skills/crafting_skill[@name='craftingWorkstations']/effect_group/passive_effect[@tags='toolForgeCrucible']/@tags">,resourceScrapIronAdvSmelt,resourceScrapBrassAdvSmelt,resourceScrapLeadAdvSmelt</append>

	<conditional>
		<if cond="game_version() &gt;= version(1,2,0) and game_version() &lt; version(1,2,5)">
			<!--Adding the advanced smelting metals to progression-->
			<append xpath="/progression/crafting_skills/crafting_skill[@name='craftingWorkstations']/display_entry[@icon='toolForgeCrucible']/unlock_entry/@item">,resourceScrapIronAdvSmelt,resourceScrapBrassAdvSmelt,resourceScrapLeadAdvSmelt</append>
		</if>
		<if cond="game_version() &gt;= version(1,2,5)">
			<append xpath="/progression/crafting_skills/crafting_skill[@name='craftingWorkstations']/display_entry[5]/unlock_entry[2]/@item">,resourceScrapIronAdvSmelt,resourceScrapBrassAdvSmelt,resourceScrapLeadAdvSmelt</append>
		</if>
	</conditional>
	
	
</AGFVanillaPlus-SmeltingPlus>
