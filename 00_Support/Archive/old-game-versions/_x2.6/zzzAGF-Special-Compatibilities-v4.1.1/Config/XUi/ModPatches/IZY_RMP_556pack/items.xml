<zzzAGF-Compatibilities>
	<!-- IZY_RMP_556pack -->
	<append xpath="/items/item[@name='ammo556mmHIpower']">
		<property name="UnlockedBy" value="perkSniperHPAmmo"/>
	</append>
	<append xpath="/items/item[@name='ammo556mmArmorPiercing']">
		<property name="UnlockedBy" value="perkSniperAPAmmo"/>
	</append>
	<append xpath="/items/item[@name='ammo556mmBulletBallBundle']">
		<property name="UnlockedBy" value="perkSniperComplete"/>
	</append>
	<append xpath="/items/item[@name='ammo556mmHIpowerBundle']">
		<property name="UnlockedBy" value="perkSniperComplete"/>
	</append>
	<append xpath="/items/item[@name='ammo556mmArmorPiercingBundle']">
		<property name="UnlockedBy" value="perkSniperComplete"/>
	</append>
	<conditional>
		<if cond="mod_loaded('AGF-VP-SimplifiedStacks')">
			<set xpath="/items/item[@name='ammo556mmBulletBall']/property[@name='Stacknumber']/@value">500</set>
			<set xpath="/items/item[@name='ammo556mmHIpower']/property[@name='Stacknumber']/@value">500</set>
			<set xpath="/items/item[@name='ammo556mmArmorPiercing']/property[@name='Stacknumber']/@value">500</set>
			<append xpath="/items/item[@name='ammo556mmBulletBallBundle']/property[@class='Action0']">
				<property name="Create_item_count" value="500"/>
			</append>
			<append xpath="/items/item[@name='ammo556mmHIpowerBundle']/property[@class='Action0']">
				<property name="Create_item_count" value="500"/>
			</append>
			<append xpath="/items/item[@name='ammo556mmArmorPiercingBundle']/property[@class='Action0']">
				<property name="Create_item_count" value="500"/>
			</append>
		</if>
	</conditional>
</zzzAGF-Compatibilities>
