<AGFVanillaPlus-ArcheryFeathersChange>


	<!--To account for if someone is also using my AmmoDisassembly mod-->	
	<!--This conditional works with version 2.5.-->
	<conditional>
		<if cond="mod_loaded('AGF-V2-VP-AmmoDisassembly') == true">
				
			<!--Adjusting the disassembly to create a feather instead of plastic-->
				<set xpath="/items/item[@name='disaArrowSteelAP']/property/property[@name='Create_item']/@value">resourceFeather,resourceArrowHeadSteelAP</set>
				<set xpath="/items/item[@name='disaArrowSteelAP']/property/property[@name='Create_item_count']/@value">1,1</set>
				
				<set xpath="/items/item[@name='disaCrossbowBoltSteelAP']/property/property[@name='Create_item']/@value">resourceFeather,resourceArrowHeadSteelAP</set>
				<set xpath="/items/item[@name='disaCrossbowBoltSteelAP']/property/property[@name='Create_item_count']/@value">1,1</set>			
				
				<set xpath="/items/item[@name='disaArrowFlaming']/property/property[@name='Create_item']/@value">resourceArrowHeadSteelAP,resourceFeather,resourceGunPowder,resourceCloth</set>
				<set xpath="/items/item[@name='disaArrowFlaming']/property/property[@name='Create_item_count']/@value">1,1,2,5</set>
				
				<set xpath="/items/item[@name='disaCrossbowBoltFlaming']/property/property[@name='Create_item']/@value">resourceArrowHeadSteelAP,resourceFeather,resourceGunPowder,resourceCloth</set>
				<set xpath="/items/item[@name='disaCrossbowBoltFlaming']/property/property[@name='Create_item_count']/@value">1,1,2,5</set>			
								
				<set xpath="/items/item[@name='disaArrowExploding']/property/property[@name='Create_item']/@value">resourceArrowHeadSteelAP,resourceFeather,resourceGunPowder</set>
				<set xpath="/items/item[@name='disaArrowExploding']/property/property[@name='Create_item_count']/@value">1,1,6</set>			
								
				<set xpath="/items/item[@name='disaCrossbowBoltExploding']/property/property[@name='Create_item']/@value">resourceArrowHeadSteelAP,resourceFeather,resourceGunPowder</set>
				<set xpath="/items/item[@name='disaCrossbowBoltExploding']/property/property[@name='Create_item_count']/@value">1,1,8</set>			
					
				
			<!--Adjusting for when you have the 100 stack of disassembly ammo to use feathers-->	
				<set xpath="/items/item[@name='disaArrowSteelAP100']/property/property[@name='Create_item']/@value">resourceFeather,resourceArrowHeadSteelAP</set>
				<set xpath="/items/item[@name='disaArrowSteelAP100']/property/property[@name='Create_item_count']/@value">100,100</set>
				
				<set xpath="/items/item[@name='disaCrossbowBoltSteelAP100']/property/property[@name='Create_item']/@value">resourceFeather,resourceArrowHeadSteelAP</set>
				<set xpath="/items/item[@name='disaCrossbowBoltSteelAP100']/property/property[@name='Create_item_count']/@value">100,100</set>			
				
				<set xpath="/items/item[@name='disaArrowFlaming100']/property/property[@name='Create_item']/@value">resourceArrowHeadSteelAP,resourceFeather,resourceGunPowder,resourceCloth</set>
				<set xpath="/items/item[@name='disaArrowFlaming100']/property/property[@name='Create_item_count']/@value">100,100,200,500</set>
				
				<set xpath="/items/item[@name='disaCrossbowBoltFlaming100']/property/property[@name='Create_item']/@value">resourceArrowHeadSteelAP,resourceFeather,resourceGunPowder,resourceCloth</set>
				<set xpath="/items/item[@name='disaCrossbowBoltFlaming100']/property/property[@name='Create_item_count']/@value">100,100,200,500</set>			
								
				<set xpath="/items/item[@name='disaArrowExploding100']/property/property[@name='Create_item']/@value">resourceArrowHeadSteelAP,resourceFeather,resourceGunPowder</set>
				<set xpath="/items/item[@name='disaArrowExploding100']/property/property[@name='Create_item_count']/@value">100,100,600</set>			
								
				<set xpath="/items/item[@name='disaCrossbowBoltExploding100']/property/property[@name='Create_item']/@value">resourceArrowHeadSteelAP,resourceFeather,resourceGunPowder</set>
				<set xpath="/items/item[@name='disaCrossbowBoltExploding100']/property/property[@name='Create_item_count']/@value">100,100,800</set>			
					
					
			<!--Adjusting for when you have the 1000 stack of disassembly ammo to use feathers-->	
				<set xpath="/items/item[@name='disaArrowSteelAP1000']/property/property[@name='Create_item']/@value">resourceFeather,resourceArrowHeadSteelAP</set>
				<set xpath="/items/item[@name='disaArrowSteelAP1000']/property/property[@name='Create_item_count']/@value">1000,1000</set>
				
				<set xpath="/items/item[@name='disaCrossbowBoltSteelAP1000']/property/property[@name='Create_item']/@value">resourceFeather,resourceArrowHeadSteelAP</set>
				<set xpath="/items/item[@name='disaCrossbowBoltSteelAP1000']/property/property[@name='Create_item_count']/@value">1000,1000</set>			
				
				<set xpath="/items/item[@name='disaArrowFlaming1000']/property/property[@name='Create_item']/@value">resourceArrowHeadSteelAP,resourceFeather,resourceGunPowder,resourceCloth</set>
				<set xpath="/items/item[@name='disaArrowFlaming1000']/property/property[@name='Create_item_count']/@value">1000,1000,2000,5000</set>
				
				<set xpath="/items/item[@name='disaCrossbowBoltFlaming1000']/property/property[@name='Create_item']/@value">resourceArrowHeadSteelAP,resourceFeather,resourceGunPowder,resourceCloth</set>
				<set xpath="/items/item[@name='disaCrossbowBoltFlaming1000']/property/property[@name='Create_item_count']/@value">1000,1000,2000,5000</set>			
								
				<set xpath="/items/item[@name='disaArrowExploding1000']/property/property[@name='Create_item']/@value">resourceArrowHeadSteelAP,resourceFeather,resourceGunPowder</set>
				<set xpath="/items/item[@name='disaArrowExploding1000']/property/property[@name='Create_item_count']/@value">1000,1000,6000</set>			
								
				<set xpath="/items/item[@name='disaCrossbowBoltExploding1000']/property/property[@name='Create_item']/@value">resourceArrowHeadSteelAP,resourceFeather,resourceGunPowder</set>
				<set xpath="/items/item[@name='disaCrossbowBoltExploding1000']/property/property[@name='Create_item_count']/@value">1000,1000,8000</set>	
		</if>					
	</conditional>			

</AGFVanillaPlus-ArcheryFeathersChange>