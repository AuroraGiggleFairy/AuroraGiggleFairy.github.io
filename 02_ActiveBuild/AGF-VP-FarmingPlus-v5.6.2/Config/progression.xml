<AGFVanillaPlus-FarmingPlus>

	<!--FARMING PLUS-->
	<!--Living off the Land maxed reduces seed crafting time by 30% while at the seed station-->
	<append xpath="/progression/perks/perk[@name='perkLivingOffTheLand']/effect_group">
		<passive_effect name="CraftingTime" operation="perc_add" level="3" value="-0.7" tags="agfSeedCrafting"/>
	</append>
	
	
	<conditional>
	
		<if cond="game_version() &gt;= version(1,2,0) and game_version() &lt; version(1,2,5)">
			<!--adds ability to craft birdnest and beeflower after reading 20 seed magazines-->
			<append xpath="/progression/crafting_skills/crafting_skill[@name='craftingSeeds']/display_entry[@unlock_level='12,14,16,18,20']/unlock_entry[@item='plantedPotato1']/@item">,birdsNestEmpty,beeFlower,advancedFarmingKey</append>
			<append xpath="/progression/crafting_skills/crafting_skill[@name='craftingSeeds']/effect_group/passive_effect[@tags='plantedPotato1']/@tags">,seedStation,birdsNestEmpty,beeFlower,plantedAloe1x5,plantedBlueberry1x5,plantedChrysanthemum1x5,plantedCoffee1x5,plantedCorn1x5,plantedCotton1x5,plantedGoldenrod1x5,plantedHop1x5,plantedMushroom1x5,plantedPotato1x5,plantedPumpkin1x5,plantedYucca1x5,birdsNestEmptyx5,beeFlowerx5,farmPlotBlockVariantHelperx5,plantedAloe1x25,plantedBlueberry1x25,plantedChrysanthemum1x25,plantedCoffee1x25,plantedCorn1x25,plantedCotton1x25,plantedGoldenrod1x25,plantedHop1x25,plantedMushroom1x25,plantedPotato1x25,plantedPumpkin1x25,plantedYucca1x25,birdsNestEmptyx25,beeFlowerx25,farmPlotBlockVariantHelperx25</append>
		</if>
		
		
		<if cond="game_version() &gt;= version(1,2,5)">
			<!--adds ability to craft birdnest  after reading 20 seed magazines-->
			<append xpath="/progression/crafting_skills/crafting_skill[@name='craftingSeeds']/display_entry[@unlock_level='12,14,16,18,20']/unlock_entry[@item='plantedPotato1']/@item">,birdsNestEmpty,advancedFarmingKey</append>
			<append xpath="/progression/crafting_skills/crafting_skill[@name='craftingSeeds']/effect_group/passive_effect[@tags='plantedPotato1']/@tags">,seedStation,birdsNestEmpty,plantedAloe1x5,plantedBlueberry1x5,plantedChrysanthemum1x5,plantedCoffee1x5,plantedCorn1x5,plantedCotton1x5,plantedGoldenrod1x5,plantedHop1x5,plantedMushroom1x5,plantedPotato1x5,plantedPumpkin1x5,plantedYucca1x5,birdsNestEmptyx5,farmPlotBlockVariantHelperx5,plantedAloe1x25,plantedBlueberry1x25,plantedChrysanthemum1x25,plantedCoffee1x25,plantedCorn1x25,plantedCotton1x25,plantedGoldenrod1x25,plantedHop1x25,plantedMushroom1x25,plantedPotato1x25,plantedPumpkin1x25,plantedYucca1x25,birdsNestEmptyx25,farmPlotBlockVariantHelperx25</append>
		</if>
		
	</conditional>
		
		
</AGFVanillaPlus-FarmingPlus>

 