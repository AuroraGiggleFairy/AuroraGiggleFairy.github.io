<AGFVanillaPlus-BuyTraderVendingMachines>


<!--Goal is to encourage player trade-->
	<!--Price is same as magazines-->
		<set xpath="/blocks/block[@name='cntVendingMachine']/property[@name='EconomicValue']/@value">100</set>
		
	<!--If you break it, you get it back-->	
		<set xpath="/blocks/block[@name='cntVendingMachine']/drop/@count">1</set>

	<!--Prevents exploits and accidents-->
		<append xpath="/blocks/block[@name='cntVendingMachine']">
			<property name="SellableToTrader" value="false"/>		
			<property name="NoScrapping" value="true"/>
		</append>
	

</AGFVanillaPlus-BuyTraderVendingMachines>
