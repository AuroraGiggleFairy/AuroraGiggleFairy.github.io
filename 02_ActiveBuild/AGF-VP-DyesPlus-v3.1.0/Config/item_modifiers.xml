<AGFVanillaPlus-DyesPlus>


<!--Invisible Dye, hides clothing items you don't want to see.-->
<!--For version 1.0, not yet sure how this may help or not.-->
		<append xpath="/item_modifiers">
			<item_modifier name="modDyeInvisible" installable_tags="clothing,armor" modifier_tags="dye,modDyeInvisible" type="attachment" cosmetic_install_chance="0">
				<property name="DescriptionKey" value="modDyeInvisibleDesc"/>
				<property name="Group" value="Science"/>
				<property name="Stacknumber" value="1"/> 
				<property name="DropMeshfile" value="@:Other/Items/Misc/sack_droppedPrefab.prefab"/>
				<property name="CustomIcon" value="modDyeWhite"/>
				<property name="Material" value="Mpaint"/>
				<property name="Weight" value="20"/>

				<item_property_overrides name="*">
							<property name="UMA.Mesh" value=""/>
							<property name="CustomIconTint" value="0,255,255"/>
							<property name="UMA.ShowAltHair" value="false"/>
				</item_property_overrides>
			</item_modifier>
		</append>
				

