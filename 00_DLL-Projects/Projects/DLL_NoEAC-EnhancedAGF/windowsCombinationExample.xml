					<rect name="vehicleDurabilitySquare" pos="84,-4" width="80" height="88" controller="HUDStatBar" stat_type="VehicleHealth">
						<sprite depth="1" name="border" color="0,0,0,235" type="sliced" />
						<sprite depth="2" name="background" color="0,0,0,140" type="sliced" />
						<filledsprite depth="3" name="background" color="86,86,86,138" width="80" type="filled" fill="{statmodifiedmax}" />
						<sprite depth="4" name="dataBand" color="0,0,0,92" width="80" height="40" pos="0,0" type="sliced" />
						<filledsprite depth="5" name="barContent" color="48,194,214,170" width="80" type="filled" fill="{statfill}" filldirection="vertical" globalopacity="false" />
						<sprite depth="6" name="tickR100" width="7" height="2" pos="73,-1" color="224,224,224,210" type="sliced" />
						<sprite depth="6" name="tickR75" width="5" height="2" pos="75,-22" color="224,224,224,210" type="sliced" />
						<sprite depth="6" name="tickR50" width="7" height="2" pos="73,-43" color="224,224,224,210" type="sliced" />
						<sprite depth="6" name="tickR25" width="5" height="2" pos="75,-64" color="224,224,224,210" type="sliced" />
						<sprite depth="6" name="tickR0" width="7" height="2" pos="73,-85" color="224,224,224,210" type="sliced" />
						<sprite depth="7" name="icon" sprite="ui_game_symbol_twitch_shield" color="230,236,242,232" size="22,22" pos="43,-62" foregroundlayer="true" />
						<label depth="6" name="TextContent" pos="50,-14" font_size="32" color="250,250,250,255" justify="center" pivot="center" text="{statcurrentwithmax}" width="46" height="24"/>
						<label depth="7" name="textCurrent" pos="72,-44" font_size="24" color="246,246,246,255" text="{agfVehicleDurabilityCurrent}" height="16" width="34" justify="right" pivot="bottomright"/>
						<label depth="7" name="textMax" pos="72,-44" font_size="18" color="230,232,236,248" text="/{agfVehicleDurabilityMax}" height="16" width="34" justify="right" pivot="topright"/>
						<sprite depth="8" name="frame" color="0,0,0,255" type="sliced" fillcenter="false" />
						<filledsprite depth="8" name="mask" color="0,0,0,255" width="80" fillcenter="false" type="filled" fill="{statmodifiedmax}" />
						<filledsprite depth="3" name="edge" color="0,0,0,255" width="80" fillcenter="false" type="filled" fill="{statmodifiedmax}" />
					</rect>
				</rect>
			</append>
		</if>
	</conditional>

	<!-- Non-Enhanced installs: full FlightAssist status box sits left of the turbo lane. -->
	<conditional>
		<if cond="mod_loaded('AGF-NoEAC-EnhancedPatch') == false and mod_loaded('AGF-NoEAC-FlightAssist')">
			<append xpath="/windows/window[@name='HUDRightStatBars']/rect[@name='vehicleStatsBase']">
				<rect name="flightAssistStatusVanilla" pos="-132,-70" width="100" height="26" disableautobackground="true" visible="{flaVehicleFlightAssistVisible}">
					<sprite depth="2" name="flightAssistBack" color="0,0,0,150" type="sliced" />
					<sprite depth="3" name="flightAssistFrameOuter" color="0,0,0,245" type="sliced" fillcenter="false" />
					<sprite depth="4" name="flightAssistFrameInner" pos="1,-1" width="98" height="24" color="120,132,142,220" type="sliced" fillcenter="false" />
					<sprite depth="5" name="flightAssistOffIcon" sprite="ui_game_symbol_gyrocopter" size="20,20" pos="20,-13" pivot="center" color="204,228,246,226" foregroundlayer="true" visible="{flaVehicleFlightAssistOffVisible}" tooltip="{flaVehicleFlightAssistOffIconTooltip}" />
					<sprite depth="5" name="flightAssistHoverIcon" sprite="ui_game_symbol_drone" size="20,20" pos="20,-13" pivot="center" color="204,228,246,226" foregroundlayer="true" visible="{flaVehicleFlightAssistHoverVisible}" tooltip_key="xuiFlightAssist_Hover_Icon_Tooltip" />
					<sprite depth="6" name="flightAssistYLockAxisDown" sprite="ui_game_symbol_drop" size="11,11" pos="17,-15" pivot="center" color="[white]" foregroundlayer="true" visible="{flaVehicleFlightAssistYLockVisible}" tooltip_key="xuiFlightAssist_YLock_Icon_Tooltip" />
					<sprite depth="6" name="flightAssistYLockAxisUp" sprite="ui_game_symbol_drop" size="11,11" pos="17,-11" pivot="center" flip="Vertically" color="[white]" foregroundlayer="true" visible="{flaVehicleFlightAssistYLockVisible}" tooltip_key="xuiFlightAssist_YLock_Icon_Tooltip" />
					<sprite depth="7" name="flightAssistYLockLock" sprite="ui_game_symbol_lock" size="12,12" pos="25,-13" pivot="center" color="[white]" foregroundlayer="true" visible="{flaVehicleFlightAssistYLockVisible}" tooltip_key="xuiFlightAssist_YLock_Icon_Tooltip" />
					<label depth="5" name="flightAssistModeText" pos="65,-13" width="64" height="16" justify="center" pivot="center" font_size="16" color="[white]" text="{flaVehicleFlightAssistModeText}" tooltip="{flaVehicleFlightAssistModeTooltip}" />
				</rect>
			</append>
		</if>
	</conditional>

	<conditional>
		<if cond="mod_loaded('AGF-NoEAC-EnhancedPatch') == false and (mod_loaded('AGF-NoEAC-AutoRun') or mod_loaded('AGF-NoEAC-FlightAssist'))">
			<append xpath="/windows/window[@name='HUDRightStatBars']/rect[@name='vehicleStatsBase']/rect[@name='modeIconsColumnVehicle']">
				<sprite depth="6" name="driveModeIndicatorVanilla" sprite="ui_game_symbol_drive" size="34,34" pos="10,-21" pivot="center" color="245,245,245,255" foregroundlayer="true" tooltip="Cruise / Auto-Run" />
			</append>
		</if>
	</conditional>

	<!-- Enhanced installs: full FlightAssist status box sits under elevation/AGL row. -->
	<conditional>
		<if cond="mod_loaded('AGF-NoEAC-EnhancedPatch') and mod_loaded('AGF-NoEAC-FlightAssist')">
			<append xpath="/windows/window[@name='HUDRightStatBars']/rect[@name='vehicleAuxPanelAGF']">
				<rect name="flightAssistStatus" pos="60,-62" width="100" height="26" disableautobackground="true" visible="{flaVehicleFlightAssistVisible}">
					<sprite depth="2" name="flightAssistBack" color="0,0,0,150" type="sliced" />
					<sprite depth="3" name="flightAssistFrameOuter" color="0,0,0,245" type="sliced" fillcenter="false" />
					<sprite depth="4" name="flightAssistFrameInner" pos="1,-1" width="98" height="24" color="120,132,142,220" type="sliced" fillcenter="false" />
					<sprite depth="5" name="flightAssistOffIcon" sprite="ui_game_symbol_gyrocopter" size="20,20" pos="20,-13" pivot="center" color="204,228,246,226" foregroundlayer="true" visible="{flaVehicleFlightAssistOffVisible}" tooltip="{flaVehicleFlightAssistOffIconTooltip}" />
					<sprite depth="5" name="flightAssistHoverIcon" sprite="ui_game_symbol_drone" size="20,20" pos="20,-13" pivot="center" color="204,228,246,226" foregroundlayer="true" visible="{flaVehicleFlightAssistHoverVisible}" tooltip_key="xuiFlightAssist_Hover_Icon_Tooltip" />
					<sprite depth="6" name="flightAssistYLockAxisDown" sprite="ui_game_symbol_drop" size="11,11" pos="17,-15" pivot="center" color="[white]" foregroundlayer="true" visible="{flaVehicleFlightAssistYLockVisible}" tooltip_key="xuiFlightAssist_YLock_Icon_Tooltip" />
					<sprite depth="6" name="flightAssistYLockAxisUp" sprite="ui_game_symbol_drop" size="11,11" pos="17,-11" pivot="center" flip="Vertically" color="[white]" foregroundlayer="true" visible="{flaVehicleFlightAssistYLockVisible}" tooltip_key="xuiFlightAssist_YLock_Icon_Tooltip" />
					<sprite depth="7" name="flightAssistYLockLock" sprite="ui_game_symbol_lock" size="12,12" pos="25,-13" pivot="center" color="[white]" foregroundlayer="true" visible="{flaVehicleFlightAssistYLockVisible}" tooltip_key="xuiFlightAssist_YLock_Icon_Tooltip" />
					<label depth="5" name="flightAssistModeText" pos="65,-13" width="64" height="16" justify="center" pivot="center" font_size="16" color="[white]" text="{flaVehicleFlightAssistModeText}" tooltip="{flaVehicleFlightAssistModeTooltip}" />
				</rect>
			</append>
		</if>
	</conditional>

	<conditional>
		<if cond="mod_loaded('AGF-NoEAC-EnhancedPatch') and (mod_loaded('AGF-NoEAC-AutoRun') or mod_loaded('AGF-NoEAC-FlightAssist'))">
			<append xpath="/windows/window[@name='HUDRightStatBars']/rect[@name='vehicleAuxPanelAGF']/rect[@name='auxModeIconsColumn']">
				<sprite depth="6" name="driveModeIndicatorExternal" sprite="ui_game_symbol_drive" size="34,34" pos="10,-21" pivot="center" color="245,245,245,255" foregroundlayer="true" tooltip="Cruise Control" />
			</append>
		</if>
	</conditional>

	<!-- AutoRun ownership can be layered similarly once behavior ownership is finalized. -->

</config>
