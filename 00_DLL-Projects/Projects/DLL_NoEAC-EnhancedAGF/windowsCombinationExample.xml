<config>

	<!--
		Combination-first example:
		1) Base HUD is unconditional (vanilla-safe).
		2) EnhancedPatch augments or overrides where it owns data/bindings.
		3) FlightAssist can add indicators even when EnhancedPatch is absent.
		4) AutoRun ownership can be layered later without rewriting the base branch.
	-->

	<!-- Base layout always applies: no mod_loaded gate required. -->
	<remove xpath="/windows/window[@name='HUDRightStatBars']/rect[2]"/>
	<append xpath="/windows/window[@name='HUDRightStatBars']">
		<rect name="vehicleStatsBase" pos="-177,106" width="168" height="96" disableautobackground="true" controller="HUDStatBar" stat_type="VehicleHealth" visible="{statvisible}">
