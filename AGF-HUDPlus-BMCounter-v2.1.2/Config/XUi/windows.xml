<AGF-HUDPlus-BMCounter-KeepDayCount>

	<conditional>
		<if cond="gamepref('BloodMoonFrequency') == 1 and gamepref('BloodMoonRange') == 0 and mod_loaded('AGF-V2-HUDPlus-1Main')">
			<append xpath="/windows/window[@name='windowCompass']">
				<rect name="counterBM" pos="70,-53" width="380">
					<!--<sprite pos="0,0" name="Background" sprite="ui_game_header_fill" color="0,0,0,225" foregroundlayer="true" height="30" width="380" type="sliced" />-->
					<label depth="3" pos="0,-4" text="{# localization('agfNextBloodMoon')}:   [{daycolor}]{# localization('01daycountdown_0')}[-]" width="380"  style="outline" font_size="22" justify="center"  height="24" visible="{showtime}"/>
				</rect>	
			</append>	
		</if>
		<if cond="gamepref('BloodMoonFrequency') == 1 and gamepref('BloodMoonRange') == 0 and mod_loaded('AGF-V2-HUDPlus-HealthBars') == false">
			<insertAfter xpath="/windows/window[@name='windowCompass']/sprite/label">						
				<label depth="3" pos="0,-26" text="{# localization('agfNextBloodMoon')}:   [{daycolor}]{# localization('01daycountdown_0')}[-]" width="300"  style="outline" font_size="22" justify="center" pivot="center" height="24" visible="{showtime}"/>
			</insertAfter>		
			<set xpath="/windows/window[@name='windowTargetBar']/rect[@pos='-200,-85']/@pos">-200,-110</set>
			<set xpath="/windows/window[@name='windowTargetBar']/rect[@pos='-267,-85']/@pos">-267,-110</set>
		</if>
	</conditional>	
	
