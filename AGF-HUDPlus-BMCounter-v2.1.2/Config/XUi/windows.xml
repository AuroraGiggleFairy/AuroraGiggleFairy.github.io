				<label depth="3" pos="0,-26" text="{# localization('agfNextBloodMoon')}:   [{daycolor}]{# localization('60daycountdown_' + day%60)}[-]"  width="300"  style="outline" font_size="22" justify="center" pivot="center" height="24" visible="{showtime}"/>
			</insertAfter>		
			<set xpath="/windows/window[@name='windowTargetBar']/rect[@pos='-200,-85']/@pos">-200,-110</set>
			<set xpath="/windows/window[@name='windowTargetBar']/rect[@pos='-267,-85']/@pos">-267,-110</set>
		</if>
	</conditional>


</AGF-HUDPlus-BMCounter-KeepDayCount>