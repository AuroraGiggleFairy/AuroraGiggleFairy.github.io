<AGFVanillaPlus-CraftStackEngBattCells>


<!--Engines now stack-->
		<set xpath="/items/item[@name='smallEngine']/property[@name='Stacknumber']/@value">500</set>
		<append xpath="/items/item[@name='smallEngine']">
			<property name="UnlockedBy" value="craftingElectrician"/>
		</append>


<!--Car Batteries now stack-->
		<set xpath="/items/item[@name='carBattery']/property[@name='ShowQuality']/@value">false</set>
		<set xpath="/items/item[@name='carBattery']/property[@name='Stacknumber']/@value">500</set>
		<set xpath="/items/item[@name='carBattery']/property[@class='Attributes']/property[@name='DegradationMax']/@value">6000</set>
		<set xpath="/items/item[@name='carBattery']/property[@class='Attributes']/property[@name='BatteryMaxLoadInVolts']/@value">36</set>
		<set xpath="/items/item[@name='carBattery']/property[@class='Attributes']/property[@name='BatteryDischargeTimeInMinutes']/@value">90</set><!--
		<set xpath="/items/item[@name='carBattery']/effect_group/property[@name='DegradationMax']/@value">10000</set>-->
		<remove xpath="/items/item[@name='carBattery']/effect_group"/>
		
		<!--Rechargeable Battery to be put into battery banks-->
		<append xpath="/items">
				<item name="carBatteryCharge">
					<property name="CustomIcon" value="utilityInsulator"/> <property name="CustomIconTint" value="930CF8"/>
					<property name="HoldType" value="45"/>
					<property name="Tags" value="junk"/>
					<property name="Meshfile" value="@:Other/Items/Misc/sackPrefab.prefab"/>
					<property name="DropMeshfile" value="@:Other/Items/Misc/sack_droppedPrefab.prefab"/>
					<property name="Stacknumber" value="1"/>
					<property name="Material" value="MelectricParts"/> <property name="Weight" value="10"/>
					<property name="EconomicValue" value="5"/>
					<property name="Group" value="Resources"/>
					<property name="DegradationBreaksAfter" value="false"/>
					<property name="ShowQuality" value="true"/>
					<property name="NoScrapping" value="true"/>					
					<property name="SellableToTrader" value="false"/>
					<property class="Attributes">
						<property name="DegradationMax" value="6000"/> 
						<property name="BatteryMaxLoadInVolts" value="36"/>
						<property name="BatteryDischargeTimeInMinutes" value="90"/>
					</property>									
					<effect_group tiered="false">
						<passive_effect name="ModSlots" operation="base_set" value="0"/>
						<passive_effect name="DegradationMax" operation="base_set" value="6000" />
					</effect_group>
				</item>
		</append>
		
			
		
<!--Solar Cells now stack and are craftable-->
		<set xpath="/items/item[@name='solarCell']/property[@name='ShowQuality']/@value">false</set>
		<set xpath="/items/item[@name='solarCell']/property[@name='Stacknumber']/@value">500</set>
		<set xpath="/items/item[@name='solarCell']/property[@class='Attributes']/property[@name='DegradationMax']/@value">6000</set>
		<remove xpath="/items/item[@name='solarCell']/effect_group"/>
		<append xpath="/items/item[@name='solarCell']">
			<property name="UnlockedBy" value="craftingElectrician"/>
		</append>


</AGFVanillaPlus-CraftStackEngBattCells>