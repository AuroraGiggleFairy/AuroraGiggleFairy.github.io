<AGFVanillaPlus-ModSlotsPlus>

<!--Made a few adjustments for version 2.0 as basic items no longer require legendary part at tier 6-->


<!--order of the following code matters-->

	<!--(Tier 3 items) auger, chainsaw, auto shotgun, sniper, M60-->	
		<set xpath="/items/item/effect_group/passive_effect[@name='ModSlots' and @value='4,4,4,4,4,4']/@value">5,5,5,5,5,6</set>
	
	<!--(Tier 2 items) steel items, impact driver, machete, smg, DV, pump shotty, tactical ar, compound bow/crossbows-->	
		<set xpath="/items/item/effect_group/passive_effect[@name='ModSlots' and @value='3,3,3,4,4,4']/@value">4,4,4,4,5,6</set>	
	
	<!--(Tier 1.5 items) Stun baton, magnum, iron crossbow-->	
		<set xpath="/items/item/effect_group/passive_effect[@name='ModSlots' and @value='2,2,3,3,4,4']/@value">3,3,3,4,4,5</set>

	<!--(Tier 1 items) iron tools/weapons, baseball bat, pistol, double barrel, hunting rifle, wooden bow, ak47-->		
		<set xpath="/items/item/effect_group/passive_effect[@name='ModSlots' and @value='2,2,2,3,3,4']/@value">3,3,3,4,4,5</set>

	<!--(Tier ? items) claw hammer, rocket launcher, robotics, armors-->		
		<set xpath="/items/item/effect_group/passive_effect[@name='ModSlots' and @value='1,1,2,2,3,4']/@value">2,2,3,4,5,6</set> 
	
	<!--(Tier 0 items) stone items, bone knife, wrench, pipe weapons, primitive bow-->
		<!--<set xpath="/items/item/effect_group/passive_effect[@name='ModSlots' and @value='1,1,1,2,2,3']/@value">1,2,3,3,3,4</set> -->

	
	<!--primitive armor only has 1 armor slot regardless of tier, and I'm going to leave it that way.-->

		
</AGFVanillaPlus-ModSlotsPlus>
