<AGFVanillaPlus-MiningPlus>
	
		
<!--A bit more sand harvesting. A little sand during the harvesting of stone and gravel.-->
		<append xpath="/blocks/block[@name='terrStone']">
			<drop event="Harvest" name="resourceCrushedSand" count="2" tag="oreWoodHarvest"/><!--Default = 0-->
		</append>
		<set xpath="/blocks/block[@name='terrGravel']/drop[@name='resourceCrushedSand']/@count">11</set><!--Default = 8-->



</AGFVanillaPlus-MiningPlus>
