<AGFVanillaPlus-MedicationNoInsectSlow>


	<!--Bee Gone Cream-->
		<append xpath="/items">
			<item name="medicalInsectCream">
				<property name="Tags" value="medical,medicalSkill"/>
				<property name="DisplayType" value="stopSlows"/>
				<property name="HoldType" value="64"/>
				<property name="CustomIcon" value="medicalAloeCream"/>
				<property name="CustomIconTint" value="217, 177, 69"/>
				<property name="Meshfile" value="@:Other/Items/Health/bandage.FBX"/>
				<property name="DropMeshfile" value="@:Other/Items/Misc/sack_droppedPrefab.prefab"/>
				<property name="Material" value="Morganic"/>
				<property name="EconomicValue" value="15"/>
				<property name="Stacknumber" value="50"/>
				<!-- STK medical -->
				<property name="Group" value="Science,CFChemicals,Medical,TCMedical"/>
				<property name="SoundPickup" value="aloe_grab"/>
				<property name="SoundPlace" value="aloe_place"/>
				<property name="UnlockedBy" value="craftingMedical"/>
				<property class="Action0">
					<property name="Class" value="Eat"/>
					<property name="Delay" value="1.0"/>
					<property name="Sound_start" value="player_ointment"/>
				</property>
				<property class="Action1">
					<property name="Class" value="UseOther"/>
					<property name="Delay" value="1.0"/>
					<property name="Sound_start" value="player_ointment"/>
				</property>
				<effect_group tiered="false">
					<display_value name="dDuration" value="180"/>
					<display_value name="dStopsSlows" value="-1"/>
					<triggered_effect trigger="onSelfPrimaryActionEnd" action="ModifyCVar" cvar="$buffInsectCreamDuration" operation="add" value="183"/>
					<triggered_effect trigger="onSelfPrimaryActionEnd" action="ModifyCVar" cvar="$buffInsectCreamDuration" operation="set" value="543">
						<requirement name="CVarCompare" cvar="$buffInsectCreamDuration" operation="GT" value="543"/>
					</triggered_effect>
					<triggered_effect trigger="onSelfPrimaryActionEnd" action="AddBuff" buff="buffProcessConsumables,buffInsectCream"/>
					<triggered_effect trigger="onSelfSecondaryActionEnd" action="ModifyCVar" target="other" cvar="$buffInsectCreamDuration" operation="add" value="183"/>
					<triggered_effect trigger="onSelfSecondaryActionEnd" action="ModifyCVar" target="other" cvar="$buffInsectCreamDuration" operation="set" value="543">
						<requirement name="CVarCompare" cvar="$buffInsectCreamDuration" target="other" operation="GT" value="543"/>
					</triggered_effect>
					<triggered_effect trigger="onSelfSecondaryActionEnd" action="AddBuff" target="other" buff="buffProcessConsumables,buffInsectCream"/>
					<triggered_effect trigger="onSelfSecondaryActionEnd" action="GiveExp" exp="10"/>
				</effect_group>
				<effect_group tiered="false">
					<!-- medical XP gains -->
					<triggered_effect trigger="onSelfPrimaryActionEnd" action="GiveExp" exp="10"/>
					<triggered_effect trigger="onSelfPrimaryActionEnd" action="GiveExp" exp="20">
						<requirement name="ProgressionLevel" progression_name="perkPhysician" operation="Equals" value="1"/>
					</triggered_effect>
					<triggered_effect trigger="onSelfPrimaryActionEnd" action="GiveExp" exp="30">
						<requirement name="ProgressionLevel" progression_name="perkPhysician" operation="Equals" value="2"/>
					</triggered_effect>
					<triggered_effect trigger="onSelfPrimaryActionEnd" action="GiveExp" exp="60">
						<requirement name="ProgressionLevel" progression_name="perkPhysician" operation="Equals" value="3"/>
					</triggered_effect>
					<triggered_effect trigger="onSelfPrimaryActionEnd" action="GiveExp" exp="60">
						<requirement name="ProgressionLevel" progression_name="perkPhysician" operation="Equals" value="4"/>
					</triggered_effect>
					<triggered_effect trigger="onSelfPrimaryActionEnd" action="GiveExp" exp="60">
						<requirement name="ProgressionLevel" progression_name="perkPhysician" operation="Equals" value="5"/>
					</triggered_effect>
				</effect_group>
				<effect_group tiered="false">
					<!-- medical XP secondary action gains -->
					<triggered_effect trigger="onSelfSecondaryActionEnd" action="GiveExp" exp="10"/>
					<triggered_effect trigger="onSelfSecondaryActionEnd" action="GiveExp" exp="20">
						<requirement name="ProgressionLevel" progression_name="perkPhysician" operation="Equals" value="1"/>
					</triggered_effect>
					<triggered_effect trigger="onSelfSecondaryActionEnd" action="GiveExp" exp="30">
						<requirement name="ProgressionLevel" progression_name="perkPhysician" operation="Equals" value="2"/>
					</triggered_effect>
					<triggered_effect trigger="onSelfSecondaryActionEnd" action="GiveExp" exp="60">
						<requirement name="ProgressionLevel" progression_name="perkPhysician" operation="Equals" value="3"/>
					</triggered_effect>
					<triggered_effect trigger="onSelfSecondaryActionEnd" action="GiveExp" exp="60">
						<requirement name="ProgressionLevel" progression_name="perkPhysician" operation="Equals" value="4"/>
					</triggered_effect>
					<triggered_effect trigger="onSelfSecondaryActionEnd" action="GiveExp" exp="60">
						<requirement name="ProgressionLevel" progression_name="perkPhysician" operation="Equals" value="5"/>
					</triggered_effect>
				</effect_group>
			</item>
		</append>


	<!--Added Display for Steroids to include this feature-->
		<append xpath="/items/item[@name='drugSteroids']/effect_group">
			<display_value name="dStopsSlows" value="-1"/>
		</append>


	<!--Modification to bee swarm and insect swarm attacks to not apply slow IF Bee Gone Cream or Steroids are active-->
		<append xpath="/items/item[@name='meleeHandAnimalInsectSwarm']/effect_group/triggered_effect[@buff='buffInjurySlow']">
			<requirement name="CVarCompare" target="other" cvar="noSlowAGF" operation="LT" value="1"/>
		</append>
		<append xpath="/items/item[@name='meleeHandAnimalBeeSwarm']/effect_group/triggered_effect[@buff='buffInjurySlow']">
			<requirement name="CVarCompare" target="other" cvar="noSlowAGF" operation="LT" value="1"/>
		</append>


</AGFVanillaPlus-MedicationNoInsectSlow>