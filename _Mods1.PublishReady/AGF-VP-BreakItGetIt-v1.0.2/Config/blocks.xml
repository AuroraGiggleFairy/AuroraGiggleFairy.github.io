<AGFVanillaPlus-BreakItGetIt>


<!--Changing blocks to harvest nothing, but get block in inventory upon breaking it.
Also adding fall chance to recover it.

campfire
dew collector
forge
workstation
cement mixer
chemistry station
table saw
writeable crates (wood, iron, steel)
wood sign (1x1, 1x3, 2x5)
-->

	<!--Campfire-->
		<remove xpath="/blocks/block[@name='campfire']/drop"/>
		<append xpath="/blocks/block[@name='campfire']">
			<drop event="Destroy" name="campfire" count="1"/>
			<drop event="Fall" name="campfire" count="1" prob="0.9" stick_chance="1"/>
		</append>

	<!--Dew Collector, if my mod DewsPlus isn't loaded-->	
		<conditional>
			<if cond="mod_loaded('AGF-VP-DewsPlus') == false"> 
				<remove xpath="/blocks/block[@name='cntDewCollector']/drop"/>
				<append xpath="/blocks/block[@name='cntDewCollector']">
					<drop event="Destroy" name="cntDewCollector" count="1"/>
					<drop event="Fall" name="cntDewCollector" count="1" prob="0.9" stick_chance="1"/>
				</append>	
			</if>
		</conditional>
		
	<!--Forge-->
		<remove xpath="/blocks/block[@name='forge']/drop"/>
		<append xpath="/blocks/block[@name='forge']">
			<drop event="Destroy" name="forge" count="1"/>
			<drop event="Fall" name="forge" count="1" prob="0.9" stick_chance="1"/>
		</append>
		
	<!--Workstation-->
		<remove xpath="/blocks/block[@name='workbench']/drop"/>
		<append xpath="/blocks/block[@name='workbench']">
			<drop event="Destroy" name="workbench" count="1"/>
			<drop event="Fall" name="workbench" count="1" prob="0.9" stick_chance="1"/>
		</append>
		
	<!--Cement Mixer-->
		<remove xpath="/blocks/block[@name='cementMixer']/drop"/>
		<append xpath="/blocks/block[@name='cementMixer']">
			<drop event="Destroy" name="cementMixer" count="1"/>
			<drop event="Fall" name="cementMixer" count="1" prob="0.9" stick_chance="1"/>
		</append>		
		
	<!--Chemistry Station-->
		<remove xpath="/blocks/block[@name='chemistryStation']/drop"/>
		<append xpath="/blocks/block[@name='chemistryStation']">
			<drop event="Destroy" name="chemistryStation" count="1"/>
			<drop event="Fall" name="chemistryStation" count="1" prob="0.9" stick_chance="1"/>
		</append>
					
	<!--Table Saw extends the cement mixer...-->
		<append xpath="/blocks/block[@name='tableSaw']">
			<dropextendsoff/><!--This is because table saw extends from cement mixer. This prevents cement mixer drops code to apply to tablesaw-->
			<drop event="Harvest" name="resourceScrapIron" count="300" tag="allHarvest,perkJunkMiner"/>
			<drop event="Harvest" name="terrStone" count="0" tool_category="Disassemble"/>
			<drop event="Harvest" name="resourceForgedIron" count="10" tag="salvageHarvest"/>
			<drop event="Harvest" name="resourceSpring" count="2" tag="salvageHarvest"/>
			<drop event="Harvest" name="resourceMechanicalParts" count="4" tag="salvageHarvest"/>
			<drop event="Destroy" count="0"/>
			<drop event="Fall" name="scrapMetalPile" count="1" prob="0.75" stick_chance="1"/>
		</append>
				
	<!--Writable Crates - Wood-->
		<remove xpath="/blocks/block[@name='cntWoodWritableCrate']/drop"/>
		<append xpath="/blocks/block[@name='cntWoodWritableCrate']">
			<drop event="Destroy" count="0"/>
			<drop event="Fall" name="cntWoodWritableCrate" count="1" prob="0.9" stick_chance="1"/>
		</append>
		
		<remove xpath="/blocks/block[@name='cntWoodWritableCrateInsecure']/drop"/>
		<append xpath="/blocks/block[@name='cntWoodWritableCrateInsecure']">
			<dropextendsoff/><!--This is because table saw extends from cement mixer. This prevents cement mixer drops code to apply to tablesaw-->
			<drop event="Destroy" name="cntWoodWritableCrate" count="1"/>
			<drop event="Fall" name="cntWoodWritableCrate" count="1" prob="0.9" stick_chance="1"/>
		</append>

	<!--Writable Crates - Iron-->
		<remove xpath="/blocks/block[@name='cntIronWritableCrate']/drop"/>
		<append xpath="/blocks/block[@name='cntIronWritableCrate']">
			<drop event="Destroy" count="0"/>
			<drop event="Fall" name="cntIronWritableCrate" count="1" prob="0.9" stick_chance="1"/>
		</append>
		
		<remove xpath="/blocks/block[@name='cntIronWritableCrateInsecure']/drop"/>
		<append xpath="/blocks/block[@name='cntIronWritableCrateInsecure']">
			<dropextendsoff/><!--This is because table saw extends from cement mixer. This prevents cement mixer drops code to apply to tablesaw-->
			<drop event="Destroy" name="cntIronWritableCrate" count="1"/>
