		</append>

	<!--Writable Crates - Steel-->
		<remove xpath="/blocks/block[@name='cntSteelWritableCrate']/drop"/>
		<append xpath="/blocks/block[@name='cntSteelWritableCrate']">
			<drop event="Destroy" count="0"/>
			<drop event="Fall" name="cntSteelWritableCrate" count="1" prob="0.9" stick_chance="1"/>
		</append>
		
		<remove xpath="/blocks/block[@name='cntSteelWritableCrateInsecure']/drop"/>
		<append xpath="/blocks/block[@name='cntSteelWritableCrateInsecure']">
			<dropextendsoff/><!--This is because table saw extends from cement mixer. This prevents cement mixer drops code to apply to tablesaw-->
			<drop event="Destroy" name="cntSteelWritableCrate" count="1"/>
			<drop event="Fall" name="cntSteelWritableCrate" count="1" prob="0.9" stick_chance="1"/>
		</append>

	<!--Wood Sign-->
		<remove xpath="/blocks/block[@name='playerSignWood1x1']/drop"/>
		<append xpath="/blocks/block[@name='playerSignWood1x1']">
			<dropextendsoff/>
			<drop event="Destroy" name="woodSignBlockVariantHelper" count="1"/>
			<drop event="Fall" name="woodSignBlockVariantHelper" count="1" prob="0.9" stick_chance="1"/>
		</append>
		<!--The other 2 wood sign sizes extend Wood1x1-->

	<!--Generator Bank-->
		<remove xpath="/blocks/block[@name='generatorbank']/drop"/>
		<append xpath="/blocks/block[@name='generatorbank']">
			<dropextendsoff/>
			<drop event="Destroy" name="generatorbank" count="1"/>
			<drop event="Fall" name="generatorbank" count="1" prob="0.9" stick_chance="1"/>
		</append>
		
	<!--Battery Bank-->
		<remove xpath="/blocks/block[@name='batterybank']/drop"/>
		<append xpath="/blocks/block[@name='batterybank']">
			<dropextendsoff/>
			<drop event="Destroy" name="batterybank" count="1"/>
			<drop event="Fall" name="batterybank" count="1" prob="0.9" stick_chance="1"/>
		</append>
	
	<!--Solar Bank-->
		<remove xpath="/blocks/block[@name='solarbank']/drop"/>
		<append xpath="/blocks/block[@name='solarbank']">
			<dropextendsoff/>
			<drop event="Destroy" name="solarbank" count="1"/>
			<drop event="Fall" name="solarbank" count="1" prob="0.9" stick_chance="1"/>
		</append>
	
	



		
</AGFVanillaPlus-BreakItGetIt>

