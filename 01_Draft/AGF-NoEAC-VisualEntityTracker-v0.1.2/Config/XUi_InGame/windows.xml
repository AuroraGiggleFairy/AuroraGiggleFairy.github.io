<AGF-VisualEntityTracker>
	<conditional evaluator="client">
		<if cond="mod_loaded('AGF-HUDPlus-1Main')">
			<!--Adding back in my version of the location/skulls and repositioned next to compass. DELETE THIS SECTION IF YOU WANT IT GONE-->
			<append xpath="/windows/window[@name='windowCompass']">
				<rect name="trackerArrowLeft" pos="14,-5" visible="{agf_vet_edge_left_visible}">
					<sprite depth="-1" sprite="ui_game_symbol_arrow_left" pos="0,0" width="28" height="22" type="sliced" color="255,0,0" globalopacity="false"/>
					<sprite depth="-2" sprite="ui_game_symbol_arrow_left" pos="-3,3" width="34" height="28" type="sliced" color="0,0,0"/>
				</rect>
				<rect name="trackerArrowRight" pos="478,-5" visible="{agf_vet_edge_right_visible}">
					<sprite depth="-1" sprite="ui_game_symbol_arrow_right" pos="0,0" width="28" height="22" type="sliced" color="255,0,0" globalopacity="false"/>
					<sprite depth="-2" sprite="ui_game_symbol_arrow_right" pos="-3,3" width="34" height="28" type="sliced" color="0,0,0"/>
				</rect>
			</append>
		</if>
		<else>										
		</else>
	</conditional>
</AGF-VisualEntityTracker>	