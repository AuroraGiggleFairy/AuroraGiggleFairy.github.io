<zzzAGF-Compatibilities>
	<!-- WMMVehicleCruiseControl -->
	<conditional>
		<if cond="mod_loaded('AGF-HUDPlus-1Main') and mod_loaded('AGF-NoEAC-EnhancedAGF') == false">
			<set xpath="/windows/window[@name='HUDRightStatBars']/rect[1]/@pos">-30,82</set>
		</if>
		<if cond="mod_loaded('AGF-HUDPlus-1Main') and mod_loaded('AGF-NoEAC-EnhancedAGF')">
			<set xpath="/windows/window[@name='HUDRightStatBars']/rect[1]/@pos">-30,132</set>
			<set xpath="/windows/window[@name='HUDRightStatBars']/rect[2]/rect[@controller='XUiC_WMMCruiseControl, WMMVehicleCruiseControl']/@pos">0,100</set>
		</if>
	</conditional>
</zzzAGF-Compatibilities>
