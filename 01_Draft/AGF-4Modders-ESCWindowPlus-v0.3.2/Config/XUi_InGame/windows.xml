<AGF-ESCWindowPlus>

   <!-- WINDOW ESC - MAIN -->
   <append xpath="/windows">
      <window name="windowESC" depth="10" width="1240" height="1080" anchor="CenterCenter" cursor_area="true">
         <rect name="tabs" controller="TabSelector" select_tab_contents_on_open="true">

            <!-- BUTTONS for FULL COLOR and HIGH VISIBILITY -->
            <rect name="tabsHeader">
               <grid name="tabButtons" pos="-525,438" depth="12" rows="2" cols="1" cell_width="170" cell_height="46" repeat_content="true" arrangement="horizontal">
                  <rect controller="TabSelectorButton">
                     <simplebutton name="tabButton" depth="12" pos="0,0" width="170" height="36" font_size="30" sprite="ui_game_header_fill" bordercolor="[pageTabButtonBorderColor]" defaultcolor="[mediumGrey]" selectedsprite="menu_empty3px" selectedcolor="[lightGrey]" foregroundlayer="false" caption="{tab_name_localized}"/>
                  </rect>
               </grid>
            </rect>

            <!-- MAIN WINDOW - MAIN -->
            <rect name="tabsContents">

               <!-- FULL COLOR - MAIN -->
               <rect name="Color" controller="TabSelectorTab" tab_key="windowESC_mode_color_tab">
                  <rect name="core" depth="10" pos="-550,460" disableautobackground="true">

                     <!-- HEADER - FULL COLOR - MAIN -->
                     <rect name="header" width="1100" height="126" globalopacity="true" globalopacitymod="1.3">
                        <sprite name="headerBackground" depth="2" pos="5,-5" sprite="ui_game_header_fill" color="[headerBackgroundColor]" width="1090" height="116" type="sliced"/>
                        <sprite name="headerBorder" depth="1" sprite="ui_game_header_fill" color="[panelBorderColor]" width="1100" height="126" type="sliced"/>
