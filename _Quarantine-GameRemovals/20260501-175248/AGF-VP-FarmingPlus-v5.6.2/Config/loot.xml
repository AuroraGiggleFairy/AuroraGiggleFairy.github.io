<AGFVanillaPlus-FarmingPlus>

	<!--Addes these seeds to be found naturally in the world, but with lower probability-->
	<append xpath="/lootcontainers/lootgroup[@name='seeds']">
		<item name="birdsNestEmpty" prob="0.05"/>
		<conditional>
			<if cond="game_version() &gt;= version(1,2,0) and game_version() &lt; version(1,2,5)">
				<item name="beeFlower" prob="0.05"/>
			</if>
		</conditional>
	</append>


	<append xpath="/lootcontainers/lootgroup[@name='seedsNoFlowers']">
		<item name="birdsNestEmpty" prob="0.05" count="1,2"/>
		<conditional>
			<if cond="game_version() &gt;= version(1,2,0) and game_version() &lt; version(1,2,5)">
				<item name="beeFlower" prob="0.05" count="1,2"/>
			</if>
		</conditional>
	</append>
		
		
</AGFVanillaPlus-FarmingPlus>