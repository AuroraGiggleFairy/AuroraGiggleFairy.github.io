<AGFVanillaPlus-BuyTraderVendingMachines>


	<!--Trader (but for player) Vending Machine with a price and trader stage requirement.-->
	<append xpath="/blocks">

		<block name="cntVendingMachine2_Player">
			<property name="Extends" value="cntVendingMachine2" param1="Buff"/>
			<property name="CustomIcon" value="cntVendingMachine2"/>
			<property name="EconomicValue" value="15000"/>
			<property name="TraderStageTemplate" value="agfTier"/>
			<property name="DescriptionKey" value="vendingMachine_playerDesc"/>
			<dropextendsoff/>
			<drop event="Destroy" name="cntVendingMachineDrinks_PlayerVariantHelper" count="1"/>
			<drop event="Fall" name="cntVendingMachineDrinks_PlayerVariantHelper" count="1" prob=".9" stick_chance=".9"/>
		</block>
		<block name="cntVendingMachineSnacksFull_Player">
			<property name="Extends" value="cntVendingMachineSnacksFull" param1="Buff"/>
			<property name="CustomIcon" value="cntVendingMachineSnacksFull"/>
			<property name="EconomicValue" value="15000"/>
			<property name="TraderStageTemplate" value="agfTier"/>
			<property name="DescriptionKey" value="vendingMachine_playerDesc"/>
			<dropextendsoff/>
			<drop event="Destroy" name="cntVendingMachineSnacksFull_Player" count="1"/>
			<drop event="Fall" name="cntVendingMachineSnacksFull_Player" count="1" prob=".9" stick_chance=".9"/>
		</block>
		<block name="cntVendingMachineEnergy_Player">
			<property name="Extends" value="cntVendingMachineEnergy" param1="Buff"/>
			<property name="CustomIcon" value="cntVendingMachineEnergy"/>
			<property name="EconomicValue" value="15000"/>
			<property name="TraderStageTemplate" value="agfTier"/>
			<property name="DescriptionKey" value="vendingMachine_playerDesc"/>
			<dropextendsoff/>
			<drop event="Destroy" name="cntVendingMachineDrinks_PlayerVariantHelper" count="1"/>
			<drop event="Fall" name="cntVendingMachineDrinks_PlayerVariantHelper" count="1" prob=".9" stick_chance=".9"/>
		</block>
		<block name="cntVendingMachineWater_Player">
			<property name="Extends" value="cntVendingMachineWater" param1="Buff"/>
			<property name="CustomIcon" value="cntVendingMachineWater"/>
			<property name="EconomicValue" value="15000"/>
			<property name="TraderStageTemplate" value="agfTier"/>
			<property name="DescriptionKey" value="vendingMachine_playerDesc"/>
			<dropextendsoff/>
			<drop event="Destroy" name="cntVendingMachineDrinks_PlayerVariantHelper" count="1"/>
			<drop event="Fall" name="cntVendingMachineDrinks_PlayerVariantHelper" count="1" prob=".9" stick_chance=".9"/>
		</block>


		<block name="cntVendingMachineDrinks_PlayerVariantHelper">
			<property name="Extends" value="cntVendingMachineWater_Player"/>
			<property name="CreativeMode" value="Player"/>
			<property name="ItemTypeIcon" value="all_blocks"/>
			<property name="DescriptionKey" value="cntFileCabinetBlockVariantHelperDesc"/>
			<property name="SelectAlternates" value="true"/>
			<property name="PlaceAltBlockValue" value="cntVendingMachineWater_Player,cntVendingMachine2_Player,cntVendingMachineEnergy_Player"/>
		</block>

	</append>




</AGFVanillaPlus-BuyTraderVendingMachines>
