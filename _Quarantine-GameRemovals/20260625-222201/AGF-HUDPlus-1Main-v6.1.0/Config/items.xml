<AGF-HUDPlus>

<!--Have to do insertafter in order to apply the new property where a book/book_read already exists-->


<!--Adding color and opacity settings to the un-read closed book icon and read open book icon.-->
<conditional>
	<if cond="mod_loaded('AGF-NoEAC-ItemTypeIconColor')">	
		<!--WITH ItemTypeIconColor Mod-->
		<insertafter xpath="/items/item/property[@name='AltItemTypeIcon' and @value='book_read']">
			<property name="AltItemTypeIconColor" value="255,255,255,220" />
			<property name="ItemTypeIconColor" value="11, 218, 81"/>
		</insertafter>
	</if>
	<else>
		<!--Without ItemTypeIconColor Mod"-->
		<insertafter xpath="/items/item/property[@name='AltItemTypeIcon' and @value='book_read']">
			<property name="AltItemTypeIconColor" value="0,255,0,180" />
		</insertafter>
	</else>
</conditional>





  
</AGF-HUDPlus>
  