<AGFVanillaPlus-MasterTool>


<insertafter xpath="/quests/quest[@id='treasure_raphael']">

	<quest id="treasure_MasterTool">
		<property name="name_key" value="treasure_MasterTool" param1="name"/>
		<property name="subtitle_key" value="treasure_MasterTool" param1="name"/>
		<property name="description_key" value="treasure_MasterTool_offer" param1="offer"/>
		<property name="icon" value="ui_game_symbol_treasure"/>
		<property name="repeatable" value="true"/>
		<property name="category_key" value="quest"/>
		<property name="offer_key" value="treasure_MasterTool_offer" param1="offer"/>
		<property name="add_to_tier_complete" value="false"/>
		<property name="difficulty_tier" value="6" param1="difficulty"/>
		<property name="shareable" value="true"/>
		<property name="login_rally_reset" value="true"/>
		<property name="reward_choices_count" value="1"/>
		<property name="return_to_quest_giver" value="true"/>
		<property name="statement_key" value="modjobsstatement"/>
		<property name="response_key" value="modjobsstatement"/>		
		<property name="quest_type" value="modjob"/>
		<property name="completiontype" value="TurnIn"/>
		<property name="completion_key" value="treasure_MasterTool_completed"/>
	
	<!--phase 1-->
		<objective type="RandomGotoNPC" phase="1">
			<property name="completion_distance" value="20"/>
			<property name="distance" value="800-1200"/>
			<property name="nav_object" value="quest"/>
			<property name="direct_nav_object" value="treasure_direct"/>
			<property name="biome_filter_type" value="AnyBiome" param1="biome_filter_type"/>
			<property name="biome_filter" value="" param1="biome_filter"/>
		</objective>		

	<!--phase 2-->
		<objective type="RallyPoint">
			<property name="start_mode" value="Create"/>
			<property name="phase" value="2"/>
			<property name="nav_object" value="rally"/>
			<property name="rally_marker_type" value="questRallyMarkerBuriedSupplies"/>			
			<property name="activate_event" value="quest_treasure_replace_road"/>
		</objective>
		<action type="SpawnGSEnemy">
			<property name="gamestage_list" value="zombieAGFMasterTool"/>
			<property name="count" value="5" param1="finish_spawn_count"/>
			<property name="phase" value="2"/>
		</action>		

	<!--phase 3-->
		<objective type="StayWithin">
			<property name="phase" value="3"/>
			<property name="radius" value="40"/>
		</objective>
		<action type="SpawnGSEnemy">
			<property name="gamestage_list" value="zombieAGFMasterTool"/>
			<property name="count" value="5" param1="finish_spawn_count"/>
			<property name="phase" value="3"/>
		</action>
		<objective type="TreasureChest">
			<property name="phase" value="3"/>
			<property name="block" value="cntBuriedFoodStashChest" param1="container"/>
			<property name="default_radius" value="20" param1="radius"/>
			<property name="container_type" value="Supplies"/>
			<property name="nav_object" value="treasure"/>
			<property name="direct_nav_object" value="treasure_direct"/>
			<property name="blocks_per_reduction" value="1"/>
			<property name="radius_reduction_sound" value="ui_radius_shrink"/>
			<property name="use_nearby" value="true"/>
			<property name="explosion_event" value="quest_treasure_explosion_horde"/>
		</objective>
		<event type="TreasureRadiusReduction">
			<action type="SpawnGSEnemy">
				<property name="gamestage_list" value="zombieAGFMasterTool"/>
				<property name="count" value="9-14" param1="spawn_count"/>
			</action>
		</event>		
		<objective type="FetchFromTreasure">
			<property name="phase" value="3"/>
			<property name="block" value="cntBuriedFoodStashChest" param1="container"/>
			<property name="quest_item_ID" value="1"/>
			<property name="item_count" value="1"/>
		</objective>

	<!--phase 4-->
		<action type="SpawnGSEnemy">
			<property name="gamestage_list" value="zombieAGFMasterTool"/>
			<property name="count" value="23" param1="finish_spawn_count"/>
			<property name="phase" value="4"/>
		</action>		
		<objective type="ReturnToNPC">
			<property name="phase" value="4"/>
			<property name="nav_object" value="return_to_trader"/>	
		</objective>		
		<objective type="InteractWithNPC">
			<property name="phase" value="4"/>
			<property name="nav_object" value="return_to_trader"/>	
		</objective>

		<reward type="Exp" value="2500"/>
		<reward type="Item" id="casinoCoin" value="10000"/>
		<reward type="Item" id="meleeMasterToolSchematic" ischosen="true" value="1"/>		
			
	</quest>

</insertafter>


<!--Puts my quest on all the trader's list.-->
	<append xpath="/quests/quest_list">
		<quest id="treasure_MasterTool"/>
	</append>



<!--Completing tier 6 quests unlocks master tool mission section-->
<append xpath="/quests/quest[@id='quest_tier6complete']">

	<action type="SetCVar">
		<property name="cvar" value="MTJobUnlocked"/>
		<property name="value" value="1"/>
		<property name="on_complete" value="true"/>
	</action>
		
</append>


</AGFVanillaPlus-MasterTool>

