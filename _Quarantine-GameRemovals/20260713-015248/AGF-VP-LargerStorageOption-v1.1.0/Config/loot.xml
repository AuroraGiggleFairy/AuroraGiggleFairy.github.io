<AGF-VP-LargerStorageOption>

	<conditional>
		<if cond="mod_loaded('AGF-BackpackPlus-072Slots') or mod_loaded('AGF-BackpackPlus-084Slots') or mod_loaded('AGF-BackpackPlus-119Slots')">
			<append xpath="/lootcontainers">
				<!-- Large Wood Crate (120); vanilla is 8x6 -->
				<lootcontainer name="playerWoodWritableStorageLarge" count="0" size="12,10" sound_open="UseActions/crate_wood_open" sound_close="UseActions/crate_wood_close" loot_quality_template="qualBaseTemplate">
					<item name="cobweb" count="0"/>
				</lootcontainer>
				<!-- Large Iron Crate (144); vanilla is 8x8 -->
				<lootcontainer name="playerIronWritableStorageLarge" count="0" size="12,12" sound_open="UseActions/crate_iron_open" sound_close="UseActions/crate_iron_close" loot_quality_template="qualBaseTemplate">
					<item name="cobweb" count="0"/>
				</lootcontainer>
				<!-- Large Steel Crate (168); vanilla is 8x10 -->
				<lootcontainer name="playerSteelWritableStorageLarge" count="0" size="12,14" sound_open="UseActions/crate_steel_open" sound_close="UseActions/crate_steel_close" loot_quality_template="qualBaseTemplate">
					<item name="cobweb" count="0"/>
				</lootcontainer>
			</append>
		</if>
		<else>
			<append xpath="/lootcontainers">
				<!-- Large Wood Crate (60); vanilla is 8x6 -->
				<lootcontainer name="playerWoodWritableStorageLarge" count="0" size="10,6" sound_open="UseActions/crate_wood_open" sound_close="UseActions/crate_wood_close" loot_quality_template="qualBaseTemplate">
					<item name="cobweb" count="0"/>
				</lootcontainer>
				<!-- Large Iron Crate (80); vanilla is 8x8 -->
				<lootcontainer name="playerIronWritableStorageLarge" count="0" size="10,8" sound_open="UseActions/crate_iron_open" sound_close="UseActions/crate_iron_close" loot_quality_template="qualBaseTemplate">
					<item name="cobweb" count="0"/>
				</lootcontainer>
				<!-- Large Steel Crate (100); vanilla is 8x10 -->
				<lootcontainer name="playerSteelWritableStorageLarge" count="0" size="10,10" sound_open="UseActions/crate_steel_open" sound_close="UseActions/crate_steel_close" loot_quality_template="qualBaseTemplate">
					<item name="cobweb" count="0"/>
				</lootcontainer>
			</append>	
		</else>
	</conditional>	
	
</AGF-VP-LargerStorageOption>
