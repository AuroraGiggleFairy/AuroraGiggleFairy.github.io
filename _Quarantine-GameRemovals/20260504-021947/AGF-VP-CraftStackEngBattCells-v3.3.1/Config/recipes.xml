<AGFVanillaPlus-CraftStackEngBattCells>

	

	<!--Batteries stack-->
		<remove xpath="/recipes/recipe[@name='carBattery']/ingredient[@name='resourceLegendaryParts']"/>
		<remove xpath="/recipes/recipe[@name='carBattery']/effect_group"/>
		<set xpath="/recipes/recipe[@name='carBattery']/ingredient[@name='resourceScrapLead']/@count">200</set>
		<set xpath="/recipes/recipe[@name='carBattery']/ingredient[@name='resourceAcid']/@count">3</set>
		<set xpath="/recipes/recipe[@name='carBattery']/ingredient[@name='resourceScrapPolymers']/@count">12</set>
		
		
		
	<!--Crafting of the Rechargeable Battery-->
		<append xpath="/recipes">
			<recipe name="carBatteryCharge">
				<ingredient name="carBattery" count="1"/>
			</recipe>		
		</append>
			
			
	<!--Crafting an Engine-->
		<append xpath="/recipes">			
			<recipe name="smallEngine" count="1" craft_area="workbench" tags="learnable,workbenchCrafting,perkAdvancedEngineering">
				<ingredient name="resourceForgedIron" count="30"/>
				<ingredient name="resourceMechanicalParts" count="30"/>
				<ingredient name="resourceElectricParts" count="12"/>
				<ingredient name="resourceOil" count="10"/>
				<ingredient name="resourceCoal" count="10"/>
				<effect_group>
					<passive_effect name="CraftingIngredientCount" level="0,1,2,3,4" operation="perc_add" value=".56,.56,.56,.34,.15" tags="resourceForgedIron,resourceMechanicalParts,resourceElectricParts,resourceOil,resourceCoal"/>
				</effect_group>
			</recipe>	
		</append>
			
			
	<!--Crafting Solar Banks and Solar Cells-->
		<append xpath="/recipes">			
			<recipe name="solarbank" count="1" craft_area="workbench" tags="learnable,workbenchCrafting,perkAdvancedEngineering">
				<ingredient name="resourceForgedSteel" count="12"/>
				<ingredient name="resourceElectricParts" count="12"/>
				<ingredient name="resourceScrapPolymers" count="10"/>
				<effect_group>
					<passive_effect name="CraftingIngredientCount" level="0,1,2,3,4" operation="perc_add" value=".56,.56,.56,.34,.15" tags="resourceForgedSteel,resourceMechanicalParts,resourceScrapPolymers"/>
				</effect_group>
			</recipe>	
			<recipe name="solarCell" count="1" craft_area="workbench" tags="learnable,workbenchCrafting,perkAdvancedEngineering">
				<ingredient name="resourceScopeLens" count="24"/>
				<ingredient name="resourceElectricParts" count="16"/>
				<ingredient name="resourceSilverNugget" count="5"/>
				<effect_group>
					<passive_effect name="CraftingIngredientCount" level="0,1,2,3,4" operation="perc_add" value=".56,.56,.56,.34,.15" tags="resourceScopeLens,resourceElectricParts,resourceSilverNugget"/>
				</effect_group>
			</recipe>	
		</append>


</AGFVanillaPlus-CraftStackEngBattCells>


