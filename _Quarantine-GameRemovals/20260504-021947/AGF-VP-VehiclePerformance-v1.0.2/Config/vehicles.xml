<AGFVanillaPlus-VehiclePerformance>


<!--velocityMax: Increased Max Speed (forward max speed , backward max speed, forward SPRINT max speed, backward SPRINT max speed)-->
		<set xpath="/vehicles/vehicle[@name='vehicleBicycle']/property[@name='velocityMax_turbo']/@value">8,4,10,4</set> <!--6,4,8.5,4 default--><!-- Old Mod 8,4,12,4-->
		<set xpath="/vehicles/vehicle[@name='vehicleMinibike']/property[@name='velocityMax_turbo']/@value">10,4,12,4</set> <!--7,4,9.2,4 default--><!-- Old Mod 10,4,14,4-->
		<set xpath="/vehicles/vehicle[@name='vehicleMotorcycle']/property[@name='velocityMax_turbo']/@value">12,8,16,10</set> <!--9.8,6,14,8 default--><!-- Old Mod 16,9,20,11-->
		<set xpath="/vehicles/vehicle[@name='vehicleTruck4x4']/property[@name='velocityMax_turbo']/@value">12,8,16,10</set> <!--10,8,14,10 default--><!-- Old Mod 14,12,18,14-->
		<set xpath="/vehicles/vehicle[@name='vehicleGyrocopter']/property[@name='velocityMax_turbo']/@value">10,4,16,6</set> <!--9,9,15,9 default--><!-- Old Mod 18,4,24,6-->
		

<!--motorTorque: acceleration power, not speed (forward , backward, forward sprint, backward sprint)-->
