<AGFVanillaPlus-FuelPlus>


		
	<!--Wood Burning Enhancement--> <!--the number of wood is equal to the default associated time-->
			<append xpath="/recipes">
				<recipe name="resourceWood10min" count="1" craft_exp_gain="0"  craft_time="2">
					<ingredient name="resourceWood" count="12"/>
				</recipe>
				<recipe name="resourceWood60min" count="1" craft_exp_gain="0"  craft_time="5">
					<ingredient name="resourceWood" count="72"/>
				</recipe>
				<recipe name="resourceWood600min" count="1" craft_exp_gain="0"  craft_time="8">
					<ingredient name="resourceWood" count="720"/>
				</recipe>
				<recipe name="resourceWood6000min" count="1" craft_exp_gain="0"  craft_time="8">
					<ingredient name="resourceWood" count="7200"/>
				</recipe>
			</append>
			
			
	<!--Coal Burning Enhancement--> <!--the number of coal is equal to the default associated time-->			
