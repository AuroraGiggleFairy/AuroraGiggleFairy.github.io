				<recipe name="resourceWood10min" count="1" craft_exp_gain="0"  craft_time="2">
					<ingredient name="resourceCoal" count="6"/>
				</recipe>
				<recipe name="resourceWood60min" count="1" craft_exp_gain="0"  craft_time="5">
					<ingredient name="resourceCoal" count="36"/>
				</recipe>
				<recipe name="resourceWood600min" count="1" craft_exp_gain="0"  craft_time="8">
					<ingredient name="resourceCoal" count="360"/>
				</recipe>
				<recipe name="resourceWood6000min" count="1" craft_exp_gain="0"  craft_time="8">
					<ingredient name="resourceCoal" count="3600"/>
				</recipe>
			</append>

	
	
</AGFVanillaPlus-FuelPlus>


