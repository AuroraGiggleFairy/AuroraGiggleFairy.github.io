<AGFVanillaPlus-TreesPlus>

<!--Icons I use for my farming plus mod to represent regular seed, x5, and x25-->
		<append xpath="/blocks/block[@name='treePlantedOak1m']">
			<property name="ItemTypeIcon" value="crops"/>
		</append>
		<append xpath="/blocks/block[@name='treePlantedMountainPine1m']">
			<property name="ItemTypeIcon" value="crops"/>
		</append>
		<append xpath="/blocks/block[@name='treePlantedWinterPine1m']">
			<property name="ItemTypeIcon" value="crops"/>
		</append>


<!--Tree Group to match farming plus scheme-->
	<append xpath="/blocks/block[@name='treePlantedOak1m']/property[@name='Group']/@value">,agfSeeds</append>
	<append xpath="/blocks/block[@name='treePlantedMountainPine1m']/property[@name='Group']/@value">,agfSeeds</append>
	<!--It's extended into this. <append xpath="/blocks/block[@name='treePlantedWinterPine1m']/property[@name='Group']/@value">,agfSeeds</append>	-->


<!--Shows Tree Name and Stage-->
	<!--Note that it does not work on the initial planted stage, because that block is weird-->
	<append xpath="/blocks/block[@name='treeMasterGrowing']">		
		<property name="DisplayInfo" value="Name"/>	
	</append>
	<append xpath="/blocks/block[@name='treePlantedOak41m']">		
		<property name="DisplayInfo" value="Name"/>	
	</append>
	<append xpath="/blocks/block[@name='treePlantedMountainPine41m']">		
		<property name="DisplayInfo" value="Name"/>	
	</append>
	<append xpath="/blocks/block[@name='treePlantedWinterPine28m']">		
		<property name="DisplayInfo" value="Name"/>	
	</append>

	
<!--x5 Trees-->
	<!--Oak Tree-->
		<append xpath="/blocks">
				<!-- *** SEEDS_OAK_TREE --> 
			<block name="treePlantedOak1mx5">
				<property name="Extends" value="treePlantedOak1m" />
				<property name="CustomIcon" value="treePlantedOak1m"/>
				<property name="CustomIconTint" value="fc8403"/>
				<property name="ItemTypeIcon" value="foliage"/>
				<property name="Group" value="agfSeedsx5"/>
				<property name="EconomicValue" value="60"/>
				<property name="PlantGrowing.Next" value="treePlantedOak08mx5"/>
				<dropextendsoff/>
				<drop event="Destroy" name="treePlantedOak1mx5" count="1"/>
			</block>

			<!-- Oak_Tree_1st_Growth_Stage -->
			<block name="treePlantedOak08mx5">
				<property name="Extends" value="treePlantedOak08m"/>
				<property name="CustomIcon" value="treeOakSml01"/>
				<property name="ItemTypeIcon" value="foliage"/>			
				<property name="EconomicValue" value="120"/>
				<property name="PlantGrowing.Next" value="treePlantedOak16mx5"/>
				<property name="MaxDamage" value="1500"/><!--default 300 by material-->
				<dropextendsoff/>
				<drop event="Harvest" name="resourceWood" count="150" tag="oreWoodHarvest,lumberjackHarvest"/><!--default 30-->
				<drop event="Destroy" name="treePlantedOak1mx5" count="1"/>
			</block>

			<!-- Oak_Tree_2nd_Growth_Stage -->
			<block name="treePlantedOak16mx5">
				<property name="Extends" value="treePlantedOak16m"/>
				<property name="CustomIcon" value="treeOakMed01"/>
				<property name="ItemTypeIcon" value="foliage"/>
				<property name="PlantGrowing.Next" value="treePlantedOak27mx5"/>
				<property name="MaxDamage" value="3000"/><!--default 600 by material-->
				<dropextendsoff/>
				<drop event="Harvest" name="resourceWood" count="350" tag="oreWoodHarvest,lumberjackHarvest"/><!--default 70-->
				<drop event="Destroy" name="treePlantedOak1mx5" count="1"/>
			</block>

			<!-- Oak_Tree_3rd_Growth_Stage -->
			<block name="treePlantedOak27mx5">
				<property name="Extends" value="treePlantedOak27m"/>
				<property name="CustomIcon" value="treeOakMed02"/>
				<property name="ItemTypeIcon" value="foliage"/>
				<property name="PlantGrowing.Next" value="treePlantedOak41mx5"/>
				<property name="MaxDamage" value="4500"/><!--default 900 by material-->
				<dropextendsoff/>
				<drop event="Harvest" name="resourceWood" count="550" tag="oreWoodHarvest,lumberjackHarvest"/><!--default 110-->
				<drop event="Destroy" name="treePlantedOak1mx5" count="1"/>
			</block>

			<!-- Oak_Tree_Final_Growth_Stage -->
			<block name="treePlantedOak41mx5">
				<property name="Extends" value="treePlantedOak41m"/>	
				<property name="DisplayInfo" value="Name"/>	
				<property name="CustomIcon" value="treeOakLrg01"/>
				<property name="ItemTypeIcon" value="foliage"/>
				<property name="MaxDamage" value="6000"/><!--default 1200 by material-->
