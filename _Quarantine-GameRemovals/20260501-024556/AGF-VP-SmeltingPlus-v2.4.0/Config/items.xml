<AGFVanillaPlus-SmeltingPlus>


	<!--Make crushed sand smelting amount equal to stones and clay. 1 full stack of 6,000 will fill it-->
		<set xpath="/items/item[@name='resourceCrushedSand']/property[@name='Weight']/@value">5</set>


	<!--These we can craft for OCD purposes. Also, makes them more apparent when you pick up a forge-->	
		<append xpath="/items/item[@name='unit_glass']">		
			<!--<property name="CustomIconTint" value="525354"/>-->	
			<property name="ItemTypeIcon" value="forge"/>
			<property name="EconomicValue" value="1"/>
			<property name="EconomicBundleSize" value="6000"/>
		</append>
		<append xpath="/items/item[@name='unit_stone']">		
			<!--<property name="CustomIconTint" value="525354"/>	-->
			<property name="ItemTypeIcon" value="forge"/>
			<property name="EconomicValue" value="1"/>
			<property name="EconomicBundleSize" value="6000"/>
		</append>
		<append xpath="/items/item[@name='unit_clay']">		
			<!--<property name="CustomIconTint" value="525354"/>	-->
			<property name="ItemTypeIcon" value="forge"/>
			<property name="EconomicValue" value="1"/>
			<property name="EconomicBundleSize" value="6000"/>
		</append>
		
		
	<!--These you don't craft as the ratio is already 1 to 1. But you can still tell them apart when dropped by a pickedup forge-->
		<append xpath="/items/item[@name='unit_iron']">		
			<!--<property name="CustomIconTint" value="525354"/>-->	
			<property name="ItemTypeIcon" value="forge"/>
			<property name="EconomicValue" value="1"/>
			<property name="EconomicBundleSize" value="6000"/>
		</append>
		<append xpath="/items/item[@name='unit_brass']">		
			<!--<property name="CustomIconTint" value="525354"/>-->	
			<property name="ItemTypeIcon" value="forge"/>
			<property name="EconomicValue" value="1"/>
			<property name="EconomicBundleSize" value="6000"/>
		</append>
		<append xpath="/items/item[@name='unit_lead']">		
			<!--<property name="CustomIconTint" value="525354"/>-->	
			<property name="ItemTypeIcon" value="forge"/>
			<property name="EconomicValue" value="1"/>
			<property name="EconomicBundleSize" value="6000"/>
		</append>


	<!--Advance Smelt for metals... A stack of 6,000 smelts 5:1 like stone.-->
		<append xpath="/items">
			<item name="resourceScrapIronAdvSmelt">
				<property name="CustomIcon" value="resourceScrapIron"/>	
				<property name="CustomIconTint" value="f77307"/>				
				<property name="ItemTypeIcon" value="forge"/>
				<property name="UnlockedBy" value="craftingWorkstations"/>
				<property name="HoldType" value="45"/>
				<property name="Meshfile" value="@:Other/Items/Misc/sackPrefab.prefab"/>
				<property name="DropMeshfile" value="@:Other/Items/Misc/sack_droppedPrefab.prefab"/>
				<property name="Material" value="MresourceScrapIron"/>
				<property name="Weight" value="5"/>
				<property name="Stacknumber" value="6000"/>
				<property name="EconomicValue" value="50"/>
				<property name="EconomicBundleSize" value="10"/>
				<property name="Group" value="Resources"/>
				<property name="CraftingIngredientTime" value=".2"/>
				<property name="SoundPickup" value="scrapiron_grab"/>
				<property name="SoundPlace" value="scrapiron_place"/>
			</item>
			<item name="resourceScrapBrassAdvSmelt">
				<property name="CustomIcon" value="resourceScrapBrass"/>
				<property name="CustomIconTint" value="f77307"/>				
				<property name="ItemTypeIcon" value="forge"/>
				<property name="UnlockedBy" value="craftingWorkstations"/>
				<property name="Tags" value="brass"/>
				<property name="HoldType" value="45"/>
				<property name="Meshfile" value="@:Other/Items/Misc/sackPrefab.prefab"/>
				<property name="DropMeshfile" value="@:Other/Items/Misc/sack_droppedPrefab.prefab"/>
				<property name="Material" value="MresourceScrapBrassSmall"/>
				<property name="MeltTimePerUnit" value=".4"/>
				<property name="Stacknumber" value="6000"/>
				<property name="Weight" value="5"/>
				<property name="EconomicValue" value="100"/>
				<property name="EconomicBundleSize" value="10"/>
				<property name="Group" value="Resources"/>
				<property name="CraftingIngredientTime" value=".2"/>
				<property name="SoundPickup" value="brass_grab"/>
				<property name="SoundPlace" value="brass_place"/>
			</item>
			<item name="resourceScrapLeadAdvSmelt">
				<property name="CustomIcon" value="resourceScrapLead"/>
				<property name="CustomIconTint" value="f77307"/>				
				<property name="ItemTypeIcon" value="forge"/>
				<property name="UnlockedBy" value="craftingWorkstations"/>
				<property name="Tags" value="lead"/>
				<property name="HoldType" value="45"/>
				<property name="Meshfile" value="@:Other/Items/Misc/sackPrefab.prefab"/>
				<property name="DropMeshfile" value="@:Other/Items/Misc/sack_droppedPrefab.prefab"/>
				<property name="Material" value="MresourceScrapLeadSmall"/>
				<property name="Stacknumber" value="6000"/>
				<property name="Weight" value="5"/>
				<property name="EconomicValue" value="50"/>
				<property name="EconomicBundleSize" value="10"/>
				<property name="Group" value="Resources"/>
				<property name="CraftingIngredientTime" value=".2"/>
				<property name="SoundPickup" value="lead_grab"/>
				<property name="SoundPlace" value="lead_place"/>
			</item>
		</append>
	
	
</AGFVanillaPlus-SmeltingPlus>