		</block>				
		<block name="carAGFbusShuttlePlanted">
			<property name="Extends" value="vehicleGrowingMaster"/>
			<property name="MultiBlockDim" value="3,4,7"/>	
			<property class="PlantGrowing">
				<property name="Next" value="cntBusShuttle" />
			</property>	
		</block>
	</append>
	
	
	
	
	
	
	
	
<!--Vehicles to downgrade into carseed.-->

	<append xpath="/blocks/block[contains(@name,'Sedan3Wide01') and not (contains(@name,'carAGF'))]">
		<property name="DowngradeBlock" value="carAGFwideSedanPlanted"/>
	</append>	
	<append xpath="/blocks/block[contains(@name,'Sedan01') and not (contains(@name,'carAGF'))]">
		<property name="DowngradeBlock" value="carAGFsedansPlanted"/>
	</append>
	
	
	<append xpath="/blocks/block[(contains(@name,'PickupTruck3Wide') or contains(@name,'SUV3Wide') or contains(@name,'03Sedan3Wide') or contains(@name,'Minivan3Wide')) and not (contains(@name,'carAGF'))]">
		<property name="DowngradeBlock" value="carAGFwide6LongPlanted"/>
	</append>	
	<append xpath="/blocks/block[(contains(@name,'PickupTruck01') or contains(@name,'SUV01') or contains(@name,'03SedanDamage') or contains(@name,'Minivan01')) and not (contains(@name,'carAGF'))]">
		<property name="DowngradeBlock" value="carAGF6LongPlanted"/>
	</append>

	
	<append xpath="/blocks/block[contains(@name,'forklift') and not (contains(@name,'carAGF'))]">
		<property name="DowngradeBlock" value="carAGFforkLiftPlanted"/>
	</append>	
	
	
	<append xpath="/blocks/block[contains(@name,'tractor') and not (contains(@name,'carAGF'))]">
		<property name="DowngradeBlock" value="carAGFtractorPlanted"/>
	</append>	
	
	
	<append xpath="/blocks/block[contains(@name,'FireTruck01') and not (contains(@name,'carAGF'))]">
		<property name="DowngradeBlock" value="carAGFfireTruckPlanted"/>
	</append>
	<!--<set xpath="/blocks/block[contains(@name,'FireTruck01')]/property[@name='PassThroughDamage']/@value">false</set>-->
	
	
	<append xpath="/blocks/block[contains(@name,'ArmyTruck') and not (contains(@name,'carAGF'))]">
		<property name="DowngradeBlock" value="carAGFarmyTruckPlanted"/>
	</append>
	
	
	<append xpath="/blocks/block[contains(@name,'FarmTruck') and not (contains(@name,'carAGF'))]">
		<property name="DowngradeBlock" value="carAGFfarmTruckPlanted"/>
	</append>
	
	
	<append xpath="/blocks/block[(contains(@name,'BoxTruck') or contains(@name,'ServiceTruck')) and not (contains(@name,'carAGF'))]">
		<property name="DowngradeBlock" value="carAGFboxTrucksPlanted"/>
	</append>	
	
	
	<append xpath="/blocks/block[contains(@name,'backhoe') and not (contains(@name,'carAGF'))]">
		<property name="DowngradeBlock" value="carAGFbackHoePlanted"/>
	</append>	
	
	
	<!-- ORDER HERE IS IMPORTANT-->
	<append xpath="/blocks/block[contains(@name,'excavator') and not (contains(@name,'carAGF'))]">
		<property name="DowngradeBlock" value="carAGFexcavatorPlanted"/>
	</append>	
	<set xpath="/blocks/block[contains(@name,'excavatorClaw')]/property[@name='DowngradeBlock']/@value">carAGFexcavatorClawPlanted</set>
	
	<!-- ORDER HERE IS IMPORTANT-->
	<append xpath="/blocks/block[contains(@name,'SemiTruck01ModularFront') and not (contains(@name,'carAGF'))]">
		<property name="DowngradeBlock" value="carAGFsemiTruckPlanted"/>
	</append>	
	<set xpath="/blocks/block[contains(@name,'SemiTruck01ModularFront')]/property[@name='DowngradeBlock']/@value">carAGFsemiTruck01ModularPlanted</set>
	
	<!--Individual Vehicles-->
	<append xpath="/blocks/block[(@name='cntPoliceCar01PickedLockBonus' or @name='cntPoliceCar01AlarmUnlocked') and not (contains(@name,'carAGF'))]">
		<property name="DowngradeBlock" value="carAGFpolicePlanted"/>	
	</append>	
	<append xpath="/blocks/block[@name='cntAmbulanceTruck01']">
		<property name="DowngradeBlock" value="carAGFambulancePlanted"/>	
	</append>	
	<append xpath="/blocks/block[@name='cntServiceTruckWorkingStiffTools']">
		<property name="DowngradeBlock" value="carAGFtruckWorkingStiffPlanted"/>	
	</append>
	<append xpath="/blocks/block[@name='cntBusCity']">
		<property name="DowngradeBlock" value="carAGFbusCityPlanted"/>	
	</append>
	<append xpath="/blocks/block[@name='cntBusSchool']">
		<property name="DowngradeBlock" value="carAGFbusSchoolPlanted"/>	
	</append>
	<append xpath="/blocks/block[@name='cntBusSchoolShort']">
		<property name="DowngradeBlock" value="carAGFbusSchoolShortPlanted"/>	
	</append>
	<append xpath="/blocks/block[@name='cntBusShuttle']">
		<property name="DowngradeBlock" value="carAGFbusShuttlePlanted"/>	
	</append>
	
	
	
</AGFVanillaPlus-AutomobilesRespawn>
