<AGFVanillaPlus-MiningPlus>



	<!-- Purple Book owns layout; this mod only inserts clay/sand unlock entries. -->

	<conditional>

		<if cond="mod_loaded('AGF-HUDPlus-PurpleBook')">



			<!-- Overview: Unlocks tab → Misc grid (small icons). -->

			<insertafter xpath="/windows/window[@name='Schematics']/rect[@name='tabs']/rect[@name='tabsContents']/rect[@name='unlockablesTab']/rect[@name='tabs']/rect[@name='tabsContents']/rect[@name='unlockAll']/grid[@name='unlockAllSectionGrid5']/entry[@name='resourceOilShaleBundle']">

				<entry name="resourceClayLumpBundle">

					<sprite depth="2" name="background" sprite="menu_empty3px" pos="3,-3" width="38" height="38" color="[darkGrey]" type="sliced" fillcenter="true" />

					<sprite depth="2" name="backgroundBorder" foregroundlayer="true" sprite="menu_empty3px" pos="3,-3" width="38" height="38" color="[black]" type="sliced" fillcenter="false" />

					<sprite depth="4" name="itemIcon" pos="5,-5" width="34" height="34" size="34,34" foregroundlayer="true" atlas="ItemIconAtlas" sprite="resourceClayLump"  tooltip_key="resourceClayLumpBundle"/>

					<filledsprite depth="3" name="background" color="0,255,0,120" pos="5,-5" width="34" height="34" fillcenter="true" type="filled" fill="{cvar(AGFperkArtOfMiningPallets)}" />

					<sprite depth="8" name="itemtypeicon" width="12" height="12" sprite="ui_game_symbol_bundle" pos="5,-5" foregroundlayer="true" color="" />

				</entry>

				<entry name="resourceCrushedSandBundle">

					<sprite depth="2" name="background" sprite="menu_empty3px" pos="3,-3" width="38" height="38" color="[darkGrey]" type="sliced" fillcenter="true" />

					<sprite depth="2" name="backgroundBorder" foregroundlayer="true" sprite="menu_empty3px" pos="3,-3" width="38" height="38" color="[black]" type="sliced" fillcenter="false" />

					<sprite depth="4" name="itemIcon" pos="5,-5" width="34" height="34" size="34,34" foregroundlayer="true" atlas="ItemIconAtlas" sprite="resourceCrushedSand"  tooltip_key="resourceCrushedSandBundle"/>

					<filledsprite depth="3" name="background" color="0,255,0,120" pos="5,-5" width="34" height="34" fillcenter="true" type="filled" fill="{cvar(AGFperkArtOfMiningPallets)}" />

					<sprite depth="8" name="itemtypeicon" width="12" height="12" sprite="ui_game_symbol_bundle" pos="5,-5" foregroundlayer="true" color="" />

				</entry>

			</insertafter>



			<!-- Zoomed: Unlocks → Misc. -->

			<insertafter xpath="/windows/window[@name='Schematics']/rect[@name='tabs']/rect[@name='tabsContents']/rect[@name='unlockablesTab']/rect[@name='tabs']/rect[@name='tabsContents']/rect[@name='unlockMisc']/grid[@name='unlockMiscGrid']/entry[@name='resourceOilShaleBundle']">

				<entry name="resourceClayLumpBundle">

					<sprite depth="2" name="background" sprite="menu_empty3px" pos="7,-7" width="80" height="80" color="[darkGrey]" type="sliced" fillcenter="true" />

					<sprite depth="2" name="backgroundBorder" foregroundlayer="true" sprite="menu_empty3px" pos="7,-7" width="80" height="80" color="[black]" type="sliced" fillcenter="false" />

					<sprite depth="4" name="itemIcon" pos="12,-12" width="70" height="70" size="70,70" foregroundlayer="true" atlas="ItemIconAtlas" sprite="resourceClayLump"  tooltip_key="resourceClayLumpBundle"/>

					<filledsprite depth="3" name="background" color="0,255,0,120" pos="12,-12" width="70" height="70" fillcenter="true" type="filled" fill="{cvar(AGFperkArtOfMiningPallets)}" />

					<sprite depth="8" name="itemtypeicon" width="18" height="18" sprite="ui_game_symbol_bundle" pos="12,-12" foregroundlayer="true" color="" />

				</entry>

				<entry name="resourceCrushedSandBundle">

					<sprite depth="2" name="background" sprite="menu_empty3px" pos="7,-7" width="80" height="80" color="[darkGrey]" type="sliced" fillcenter="true" />

					<sprite depth="2" name="backgroundBorder" foregroundlayer="true" sprite="menu_empty3px" pos="7,-7" width="80" height="80" color="[black]" type="sliced" fillcenter="false" />

					<sprite depth="4" name="itemIcon" pos="12,-12" width="70" height="70" size="70,70" foregroundlayer="true" atlas="ItemIconAtlas" sprite="resourceCrushedSand"  tooltip_key="resourceCrushedSandBundle"/>

					<filledsprite depth="3" name="background" color="0,255,0,120" pos="12,-12" width="70" height="70" fillcenter="true" type="filled" fill="{cvar(AGFperkArtOfMiningPallets)}" />

					<sprite depth="8" name="itemtypeicon" width="18" height="18" sprite="ui_game_symbol_bundle" pos="12,-12" foregroundlayer="true" color="" />

				</entry>

			</insertafter>



		</if>

	</conditional>



</AGFVanillaPlus-MiningPlus>

