<zzzAGF-Compatibilities>
	<!-- IZY_RMP_SG -->
	<append xpath="/items/item[contains(@name,'Shotgun')]/property[@class='Action0']/property[@name='Magazine_items']/@value">,ammoShotgunShellPremium</append>
	<conditional>
		<if cond="mod_loaded('AGF-VP-SimplifiedStacks') == false">
			<append xpath="/items">
				<item name="ammoShotgunShellPremiumBundle">
					<property name="Extends" value="ammoBundleMaster"/>
					<property name="CustomIcon" value="ammoShotgunShellPremium"/>
					<property name="Stacknumber" value="10"/>
					<property name="EconomicValue" value="900"/>
					<property name="TraderStageTemplate" value="ammoTier3"/>
					<property name="UnlockedBy" value="perkShotgunMessiahComplete"/>
					<property class="Action0">
						<property name="Create_item" value="ammoShotgunShellPremium"/>
						<property name="Create_item_count" value="100"/>
					</property>
				</item>
			</append>
		</if>
		<if cond="mod_loaded('AGF-VP-SimplifiedStacks')">
			<append xpath="/items">
				<item name="ammoShotgunShellPremiumBundle">
					<property name="Extends" value="ammoBundleMaster"/>
					<property name="CustomIcon" value="ammoShotgunShellPremium"/>
					<property name="Stacknumber" value="50"/>
					<property name="EconomicValue" value="900"/>
					<property name="TraderStageTemplate" value="ammoTier3"/>
					<property name="UnlockedBy" value="perkShotgunMessiahComplete"/>
					<property class="Action0">
						<property name="Create_item" value="ammoShotgunShellPremium"/>
						<property name="Create_item_count" value="500"/>
					</property>
				</item>
			</append>
			<set xpath="/items/item[@name='ammoShotgunShellPremium']/property[@name='Stacknumber']/@value">500</set>
		</if>
	</conditional>
	<conditional>
		<if cond="mod_loaded('V2_OakravenAmmoPress')">
			<append xpath="/items/item[@name='ammoShotgunShellPremium']">
				<property name="Group" value="Ammo/Weapons,Ammo,Ranged Weapons,RegularAmmo"/>
			</append>
			<append xpath="/items/item[@name='ammoShotgunShellPremiumBundle']">
				<property name="Group" value="Ammo/Weapons,Ammo,Ranged Weapons,RegularAmmo"/>
			</append>
		</if>
	</conditional>
	<conditional>
		<if cond="mod_loaded('AGF-VP-AmmoDisassembly')">
			<!-- Modifications to the Ammo-->
			<append xpath="/items/item[@name='ammoShotgunShellPremium']">
				<property name="Material" value="MammoShotgunShellPremium"/>
				<property name="Weight" value="1"/>
			</append>
			<!-- The Disassembled Bundles-->
			<append xpath="/items">
				<!-- x1 -->
				<item name="disaShotgunShellPremium">
					<property name="Extends" value="disa9mmBulletBall"/>
					<property name="CustomIcon" value="ammoShotgunShellPremium"/>
					<property name="Material" value="MammoShotgunShellPremium"/>
					<property class="Action0">
						<property name="Create_item" value="resourceBuckshot,resourceGunPowder,resourceScrapPolymers"/>
						<property name="Create_item_count" value="1,6,1"/>
					</property>
				</item>
				<!-- x100 -->
				<item name="disaShotgunShellPremium100">
					<property name="Extends" value="disa9mmBulletBall100"/>
					<property name="CustomIcon" value="ammoShotgunShellPremium"/>
					<property name="Material" value="MammoShotgunShellPremium"/>
					<property class="Action0">
						<property name="Create_item" value="resourceBuckshot,resourceGunPowder,resourceScrapPolymers"/>
						<property name="Create_item_count" value="100,600,100"/>
					</property>
				</item>
				<!-- x1000-->
				<item name="disaShotgunShellPremium1000">
					<property name="Extends" value="disa9mmBulletBall1000"/>
					<property name="CustomIcon" value="ammoShotgunShellPremium"/>
					<property name="Material" value="MammoShotgunShellPremium"/>
					<property class="Action0">
						<property name="Create_item" value="resourceBuckshot,resourceGunPowder,resourceScrapPolymers"/>
						<property name="Create_item_count" value="1000,6000,1000"/>
					</property>
				</item>
			</append>
		</if>
	</conditional>
</zzzAGF-Compatibilities>
