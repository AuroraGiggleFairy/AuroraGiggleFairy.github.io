					<ingredient name="ammo45ACPBulletBall" count="100"/>
				</recipe>
				<recipe name="ammoBundle45ACPHighpower" count="1" craft_time="2" craft_exp_gain="0" tags="learnable">
					<ingredient name="ammo45ACPHighpower" count="100"/>
				</recipe>
