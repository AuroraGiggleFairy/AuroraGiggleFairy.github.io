				<recipe name="ammoBundle45ACPEnhanced" count="1" craft_time="2" craft_exp_gain="0" tags="learnable">
					<ingredient name="ammo45ACPEnhanced" count="500"/>
				</recipe>
			</append>
		</if>
	</conditional>
