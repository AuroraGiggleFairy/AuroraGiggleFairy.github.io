<AGFVanillaPlus-AdminModdingSupport>


	<!--Test Blocks for modders-->
	<!--These blocks have set harvest amounts in the 10's. Easier to see if any tool edits or new tools modded in work as intended.-->
		<append xpath="blocks">
			<block name="agfTestButcherBlock">
				<!-- Baseline harvest tuning: simple no-perk validation uses 10-item drops. -->
				<property name="CreativeMode" value="Dev"/>
				<!-- ^^^ Only accessible via creative menu with DEV / ADMIN selected-->
				<property name="CustomIcon" value="goreBlockAnimal"/>
				<property name="CustomIconTint" value="930CF8"/>
				<property name="Material" value="Morganic"/>
				<property name="MaxDamage" value="10"/>
				<property name="Shape" value="ModelEntity"/>
				<property name="Model" value="@:Entities/Gore/animalRemainsGorePrefab.prefab"/>
				<property name="Collide" value="melee,bullet,arrow,rocket"/>
				<property name="IsTerrainDecoration" value="true"/>
				<property name="FallDamage" value=".9"/>
				<property name="ImposterExclude" value="true"/>
				<property name="ImposterDontBlock" value="true"/>
				<property name="Density" value="0.9"/>
				<drop event="Harvest" name="foodRottingFlesh" count="10" tag="allHarvest" tool_category="Butcher"/>
				<drop event="Harvest" name="foodRottingFlesh" count="10" tag="butcherHarvest"/>
				<drop event="Harvest" name="resourceAnimalFat" count="10" tag="butcherHarvest"/>
				<drop event="Harvest" name="resourcePotassiumNitratePowder" count="10" tag="butcherHarvest"/>
				<drop event="Destroy" name="resourceBone" count="10" tag="butcherHarvest"/>
				<property name="DescriptionKey" value="creativeMenuBlockGroupDesc"/>
				<property name="FilterTags" value="MC_building,SC_decor"/>
				<property name="SortOrder1" value="7000"/>
				<property name="SortOrder2" value="0002"/>
			</block>
			<block name="agfTestSalvageBlock">
				<!-- Baseline harvest tuning: simple no-perk validation uses 10-item drops. -->
				<property name="CreativeMode" value="Dev"/>
				<!-- ^^^ Only accessible via creative menu with DEV / ADMIN selected-->
				<property name="CustomIcon" value="cntCar03SedanDamage2Master"/>
				<property name="CustomIconTint" value="930CF8"/>
				<property name="Material" value="Mmetal"/>
				<property name="Shape" value="ModelEntity"/>
				<property name="ImposterDontBlock" value="true"/>
				<property name="IsTerrainDecoration" value="true"/>
				<property name="Model" value="@:Entities/Vehicles/Sedan/sedanPrefab.prefab"/>
				<property name="Place" value="TowardsPlacer"/>
				<property name="ModelOffset" value="-0.5,0,0"/>
				<property name="TintColor" value="B0B0B0"/>
				<property name="OversizedBounds" value="(-0.5,0.5,0),(2,2,5)"/>
				<property name="DisplayType" value="blockMulti"/>
				<property name="MultiBlockDim" value="2,2,6"/>
				<property name="ShowModelOnFall" value="false"/>
				<drop event="Harvest" name="terrStone" count="0" tool_category="Disassemble"/>
				<drop event="Harvest" name="ammoGasCan" count="10" tag="salvageHarvest"/>
				<drop event="Harvest" name="resourceScrapPolymers" count="10" tag="salvageHarvest"/>
				<drop event="Harvest" name="resourceOil" count="10" tag="salvageHarvest"/>
				<drop event="Harvest" name="resourceMechanicalParts" count="10" tag="salvageHarvest"/>
				<drop event="Harvest" name="resourceElectricParts" count="10" tag="salvageHarvest"/>
				<drop event="Harvest" name="resourceSpring" count="10" tag="salvageHarvest"/>
				<drop event="Harvest" name="resourceScrapIron" count="10" tag="allHarvest"/>
				<drop event="Destroy" count="0"/>
				<property name="DescriptionKey" value="creativeMenuBlockGroupDesc"/>
				<property name="PlacementDistance" value="6"/>
				<property name="FilterTags" value="MC_building,SC_decor"/>
				<property name="SortOrder1" value="7000"/>
				<property name="SortOrder2" value="0002"/>
			</block>			
			<block name="agfTestMiningBlock">
				<!-- Baseline harvest tuning: simple no-perk validation uses 10-item drops. -->
				<property name="CreativeMode" value="Dev"/>
				<!-- ^^^ Only accessible via creative menu with DEV / ADMIN selected-->
				<property name="CustomIcon" value="terrOreIron"/>
				<property name="CustomIconTint" value="930CF8"/>
				<property name="CanMobsSpawnOn" value="false"/>
				<property name="DescriptionKey" value="terrainBlockGroupDesc"/>
				<property name="DisplayType" value="blockTerrain"/>
				<property name="Map.Color" value="255,150,50"/>
				<property name="Material" value="MoreMetal"/>
				<property name="Shape" value="Terrain"/>
				<property name="Mesh" value="terrain"/>
				<property name="Texture" value="33"/>
				<property name="MaxDamage" value="10"/>
				<property name="ImposterExclude" value="true"/>
				<drop event="Harvest" name="resourceScrapIron" count="10" tag="oreWoodHarvest"/>
				<drop event="Destroy" count="0"/>
				<drop event="Fall" name="resourceScrapIron" count="150" prob="0.4" stick_chance="0"/>
				<property name="SortOrder1" value="0000"/>
				<property name="SortOrder2" value="0950"/>
				<property name="Tags" value="ore,deepOre"/>
				<property name="FilterTags" value="MC_outdoor,SC_terrain"/>
			</block>			
			<block name="agfTestWoodBlock">
				<!-- Baseline harvest tuning: simple no-perk validation uses 10-item drops. -->
				<property name="CreativeMode" value="Dev"/>
				<!-- ^^^ Only accessible via creative menu with DEV / ADMIN selected-->
				<property name="CustomIcon" value="treeDeadTree01"/>
				<property name="CustomIconTint" value="930CF8"/>
				<property name="Extends" value="treeMaster"/>
				<property name="Model" value="#Entities/Trees?StudioGimbal/White_Oak22/White_Oak22GimbalPrefab.prefab"/>
				<property name="ModelOffset" value="0,-0.3,0"/>
				<property name="MultiBlockDim" value="1,4,1"/>
				<property name="Collide" value="movement,melee,bullet,arrow,rocket"/>
				<property name="Path" value="solid"/>
				<property name="BigDecorationRadius" value="4"/>
				<property name="MaxDamage" value="10"/>
				<property name="ParticleOnDeath" value="treeGib_dead_01"/>
				<drop event="Harvest" name="resourceWood" count="10" tag="oreWoodHarvest,lumberjackHarvest"/>
				<property name="SortOrder1" value="B901"/>
			</block>
		</append>
</AGFVanillaPlus-AdminModdingSupport>
