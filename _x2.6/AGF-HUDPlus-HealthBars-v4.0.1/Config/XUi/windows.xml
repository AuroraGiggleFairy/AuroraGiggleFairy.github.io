<AGF-HUDPlus-HealthBars>


	<!--Target Bar, AGF style-->
		<!--Sets enemy health bars to be shown whenever, not just in gode mode-->
		<set xpath="/windows/window[@name='windowTargetBar']/@visibility">always</set>

		<!--Overall window positioning and size-->
		<set xpath="/windows/window[@name='windowTargetBar']/rect[@visible='{isnotboss}']/@pos">-199,-110</set> 
		<set xpath="/windows/window[@name='windowTargetBar']/rect[@visible='{isnotboss}']/@width">400</set>
		<set xpath="/windows/window[@name='windowTargetBar']/rect[@visible='{isnotboss}']/@height">40</set>

		<set xpath="/windows/window[@name='windowTargetBar']/rect[@visible='{isboss}']/@pos">-267,-110</set> <!--lowers the boss to same vertical height-->

		<!--Added a dark Border to the health bar-->
		<append xpath="/windows/window[@name='windowTargetBar']/rect[@visible='{isnotboss}']">	
			<sprite depth="3" name="border2" pos="-2,2" width="402" height="42" sprite="menu_empty2px" color="[black]" type="sliced" fillcenter="false"/>
		</append>

		<!--Made the background of the healthbar a bit darker-->
		<set xpath="/windows/window[@name='windowTargetBar']/rect[@visible='{isnotboss}']/sprite[@name='border']/@color">100,100,100,225</set>
		
		<!--set the width to the shorter width I made above-->
		<set xpath="/windows/window[@name='windowTargetBar']/rect[@visible='{isnotboss}']/sprite[@name='border']/@width">400</set>


		<!--Darker Red Color for enemy health-->
		<set xpath="/windows/window[@name='windowTargetBar']/rect[@visible='{isnotboss}']/filledsprite/@color">150,0,0,255</set>
		
		<!--set the width to the shorter width I made above-->
		<set xpath="/windows/window[@name='windowTargetBar']/rect[@visible='{isnotboss}']/filledsprite/@width">400</set>


		<!--Text-->
		<set xpath="/windows/window[@name='windowTargetBar']/rect[@visible='{isnotboss}']/label/@pos">0,-6</set>
		<set xpath="/windows/window[@name='windowTargetBar']/rect[@visible='{isnotboss}']/label/@font_size">28</set>
		<set xpath="/windows/window[@name='windowTargetBar']/rect[@visible='{isnotboss}']/label/@justify">center</set>
		<set xpath="/windows/window[@name='windowTargetBar']/rect[@visible='{isnotboss}']/label/@height">28</set>
		<set xpath="/windows/window[@name='windowTargetBar']/rect[@visible='{isnotboss}']/label/@text">{name}:  {currentwithmax}</set>
		

</AGF-HUDPlus-HealthBars>