<zzzAGF-Compatibilities>
	<!-- IZY_RMP_Miscpack -->
	<conditional>
		<if cond="mod_loaded('AGF-HUDPlus-PurpleBook')">
			<!--All Checklist - Section 5 of Archery -->
			<append xpath="/windows/window[@name='Schematics']/rect[@name='tabs']/rect[@name='tabsContents']/rect[@name='craftinglistTab']/rect[@name='tabs']/rect[@name='tabsContents']/rect[@name='allChecklists']/rect[@name='checklistArchery']/rect[6]">
				<sprite name="itemIcon" depth="3" pos="26,-35" size="21,21" foregroundlayer="true" atlas="ItemIconAtlas" sprite="IZYgunT4BowVanhelsingAutomaticCrossbowVH" color="" tooltip_key="IZYgunT4BowVanhelsingAutomaticCrossbowVH"/>
			</append>
			<!--Zoomed Checklist - Section 5 of Archery-->
			<set xpath="/windows/window[@name='Schematics']/rect[@name='tabs']/rect[@name='tabsContents']/rect[@name='craftinglistTab']/rect[@name='tabs']/rect[@name='tabsContents']/rect[@name='zoomedArchery']/grid[@name='checklistArchery']/entry[5]/sprite[@sprite='gunBowT3CompoundCrossbow']/@pos">100,-40</set>
			<insertafter xpath="/windows/window[@name='Schematics']/rect[@name='tabs']/rect[@name='tabsContents']/rect[@name='craftinglistTab']/rect[@name='tabs']/rect[@name='tabsContents']/rect[@name='zoomedArchery']/grid[@name='checklistArchery']/entry[5]/sprite[@sprite='gunBowT3CompoundCrossbow']">
				<sprite name="itemIcon" depth="3" pos="150,-40" size="50,50" foregroundlayer="true" atlas="ItemIconAtlas" sprite="IZYgunT4BowVanhelsingAutomaticCrossbowVH" color="" tooltip_key="IZYgunT4BowVanhelsingAutomaticCrossbowVH"/>
			</insertafter>
			<!--Unlocks Section-->
			<insertafter xpath="/windows/window[@name='Schematics']/rect[@name='tabs']/rect[@name='tabsContents']/rect[@name='unlockablesTab']/grid/entry[@name='ammoBundleCrossbowBoltExploding']">
				<entry name="item">
					<sprite depth="2" name="background" sprite="menu_empty3px" pos="5,-5" width="70" height="70" color="[darkGrey]" type="sliced" fillcenter="true"/>
					<sprite depth="2" name="backgroundBorder" foregroundlayer="true" sprite="menu_empty3px" pos="5,-5" width="70" height="70" color="[black]" type="sliced" fillcenter="false"/>
					<sprite depth="4" name="itemIcon" pos="8,-8" width="64" height="64" size="64,64" foregroundlayer="true" atlas="ItemIconAtlas" sprite="ammoCrossbowLightBoltStone" color="" tooltip_key="ammoCrossbowLightBoltStone"/>
					<filledsprite depth="3" name="background" color="0,255,0,120" pos="8,-8" width="64" height="64" fillcenter="true" type="filled" fill="1"/>
					<sprite depth="8" name="itemtypeicon" width="24" height="24" sprite="" pos="9,-9" foregroundlayer="true" color=""/>
				</entry>
				<entry name="item">
					<sprite depth="2" name="background" sprite="menu_empty3px" pos="5,-5" width="70" height="70" color="[darkGrey]" type="sliced" fillcenter="true"/>
					<sprite depth="2" name="backgroundBorder" foregroundlayer="true" sprite="menu_empty3px" pos="5,-5" width="70" height="70" color="[black]" type="sliced" fillcenter="false"/>
					<sprite depth="4" name="itemIcon" pos="8,-8" width="64" height="64" size="64,64" foregroundlayer="true" atlas="ItemIconAtlas" sprite="ammoCrossbowLighBoltIron" color="" tooltip_key="ammoCrossbowLightBoltIron"/>
					<filledsprite depth="3" name="background" color="0,255,0,120" pos="8,-8" width="64" height="64" fillcenter="true" type="filled" fill="1"/>
					<sprite depth="8" name="itemtypeicon" width="24" height="24" sprite="" pos="9,-9" foregroundlayer="true" color=""/>
				</entry>
				<entry name="item">
					<sprite depth="2" name="background" sprite="menu_empty3px" pos="5,-5" width="70" height="70" color="[darkGrey]" type="sliced" fillcenter="true"/>
					<sprite depth="2" name="backgroundBorder" foregroundlayer="true" sprite="menu_empty3px" pos="5,-5" width="70" height="70" color="[black]" type="sliced" fillcenter="false"/>
					<sprite depth="4" name="itemIcon" pos="8,-8" width="64" height="64" size="64,64" foregroundlayer="true" atlas="ItemIconAtlas" sprite="ammoCrossbowLighBoltSteelAP" color="" tooltip_key="ammoCrossbowLightBoltSteelAP"/>
					<filledsprite depth="3" name="background" color="0,255,0,120" pos="8,-8" width="64" height="64" fillcenter="true" type="filled" fill="{cvar(AGFperkRangersAPAmmo)}"/>
					<sprite depth="8" name="itemtypeicon" width="24" height="24" sprite="" pos="9,-9" foregroundlayer="true" color=""/>
				</entry>
			</insertafter>
		</if>
	</conditional>
</zzzAGF-Compatibilities>
