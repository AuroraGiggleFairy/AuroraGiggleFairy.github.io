<zzzAGF-Compatibilities>
	<!-- IZY_RMP_Miscpack -->
	<append xpath="/items/item[@name='ammoCrossbowLightBoltStone']">
		<property name="DescriptionKey" value="lightboltdesc"/>
	</append>
	<append xpath="/items/item[@name='ammoCrossbowLightBoltIron']">
		<property name="DescriptionKey" value="lightboltdesc"/>
	</append>
	<append xpath="/items/item[@name='ammoCrossbowLightBoltSteelAP']">
		<property name="UnlockedBy" value="perkRangersAPAmmo"/>
		<property name="DescriptionKey" value="lightboltdesc"/>
	</append>
	<conditional>
		<if cond="mod_loaded('AGF-VP-SimplifiedStacks')">
			<set xpath="/items/item[@name='ammoCrossbowLightBoltStone']/property[@name='Stacknumber']/@value">500</set>
			<set xpath="/items/item[@name='ammoCrossbowLightBoltIron']/property[@name='Stacknumber']/@value">500</set>
			<set xpath="/items/item[@name='ammoCrossbowLightBoltSteelAP']/property[@name='Stacknumber']/@value">500</set>
		</if>
	</conditional>
</zzzAGF-Compatibilities>
