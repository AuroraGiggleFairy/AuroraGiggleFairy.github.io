<zzzAGF-Compatibilities>
	<!-- IZY_RMP_Demopack -->
	<append xpath="/recipes/recipe[@name='ammo25mmGrenadeTraining']/@tags">,learnable</append>
	<append xpath="/recipes/recipe[@name='ammo25mmGrenadeHE']/@tags">,learnable</append>
	<append xpath="/recipes/recipe[@name='ammo25mmGrenadeFRAGS']/@tags">,learnable</append>
	<append xpath="/recipes/recipe[@name='ammoRocketRPGTraning']/@tags">,learnable</append>
	<append xpath="/recipes/recipe[@name='ammoRocketRPGHE']/@tags">,learnable</append>
	<append xpath="/recipes/recipe[@name='ammoRocketRPGIncendiary']/@tags">,learnable</append>
	<conditional>
		<if cond="mod_loaded('AGF-VP-AmmoDisassembly')">
			<!-- Removing the other rocket recipes that take vanilla rockets. And keeping the base ones-->
			<remove xpath="/recipes/recipe[@name='ammoRocketRPGHE']"/>
			<remove xpath="/recipes/recipe[@name='ammoRocketRPGIncendiary']"/>
			<append xpath="/recipes">
				<recipe name="ammoRocketRPGTraning" count="1" craft_time="50" craft_area="workbench" tags="workbenchCrafting,learnable">
					<ingredient name="resourceRocketTip" count="1"/>
					<ingredient name="resourceRocketCasing" count="1"/>
					<ingredient name="resourceDuctTape" count="2"/>
					<ingredient name="resourceForgedSteel" count="1"/>
					<ingredient name="resourceGunPowder" count="15"/>
				</recipe>
				<recipe name="ammoRocketRPGHE" count="1" craft_time="50" craft_area="workbench" tags="workbenchCrafting,learnable">
					<ingredient name="resourceRocketTip" count="1"/>
					<ingredient name="resourceRocketCasing" count="1"/>
					<ingredient name="resourceDuctTape" count="2"/>
					<ingredient name="resourceGunPowder" count="40"/>
				</recipe>
				<recipe name="ammoRocketRPGIncendiary" count="1" craft_time="50" craft_area="workbench" tags="workbenchCrafting,learnable">
					<ingredient name="resourceRocketTip" count="1"/>
					<ingredient name="resourceRocketCasing" count="1"/>
					<ingredient name="resourceDuctTape" count="2"/>
					<ingredient name="resourceGunPowder" count="30"/>
					<ingredient name="ammoGasCan" count="300"/>
				</recipe>
			</append>
		</if>
	</conditional>
	<conditional>
		<if cond="mod_loaded('AGF-VP-AmmoDisassembly')">
			<append xpath="/recipes">
				<recipe name="disaRocketRPGTraning" count="1" tooltip="ttScrapMetalBrass" always_unlocked="true" tags="salvageScrap">
					<wildcard_forge_category/>
				</recipe>
				<recipe name="disaRocketRPGHE" count="1" tooltip="ttScrapMetalBrass" always_unlocked="true" tags="salvageScrap">
					<wildcard_forge_category/>
				</recipe>
				<recipe name="disaRocketRPGIncendiary" count="1" tooltip="ttScrapMetalBrass" always_unlocked="true" tags="salvageScrap">
					<wildcard_forge_category/>
				</recipe>
				<recipe name="disa25mmGrenadeTraining" count="1" tooltip="ttScrapMetalBrass" always_unlocked="true" tags="salvageScrap">
					<wildcard_forge_category/>
				</recipe>
				<recipe name="disa25mmGrenadeFRAGS" count="1" tooltip="ttScrapMetalBrass" always_unlocked="true" tags="salvageScrap">
					<wildcard_forge_category/>
				</recipe>
				<recipe name="disa25mmGrenadeHE" count="1" tooltip="ttScrapMetalBrass" always_unlocked="true" tags="salvageScrap">
					<wildcard_forge_category/>
				</recipe>
				<recipe name="disaRocketRPGTraning100" count="1" craft_time="1">
					<ingredient name="disaRocketRPGTraning" count="100"/>
				</recipe>
				<recipe name="disaRocketRPGHE100" count="1" craft_time="1">
					<ingredient name="disaRocketRPGHE" count="100"/>
				</recipe>
				<recipe name="disaRocketRPGIncendiary100" count="1" craft_time="1">
					<ingredient name="disaRocketRPGIncendiary" count="100"/>
				</recipe>
				<recipe name="disa25mmGrenadeTraining100" count="1" craft_time="1">
					<ingredient name="disa25mmGrenadeTraining" count="100"/>
				</recipe>
				<recipe name="disa25mmGrenadeFRAGS100" count="1" craft_time="1">
					<ingredient name="disa25mmGrenadeFRAGS" count="100"/>
				</recipe>
				<recipe name="disa25mmGrenadeHE100" count="1" craft_time="1">
					<ingredient name="disa25mmGrenadeHE" count="100"/>
				</recipe>
				<recipe name="disaRocketRPGTraning1000" count="1" craft_time="1">
					<ingredient name="disaRocketRPGTraning" count="1000"/>
				</recipe>
				<recipe name="disaRocketRPGHE1000" count="1" craft_time="1">
					<ingredient name="disaRocketRPGHE" count="1000"/>
				</recipe>
				<recipe name="disaRocketRPGIncendiary1000" count="1" craft_time="1">
					<ingredient name="disaRocketRPGIncendiary" count="1000"/>
				</recipe>
				<recipe name="disa25mmGrenadeTraining1000" count="1" craft_time="1">
					<ingredient name="disa25mmGrenadeTraining" count="1000"/>
				</recipe>
				<recipe name="disa25mmGrenadeFRAGS1000" count="1" craft_time="1">
					<ingredient name="disa25mmGrenadeFRAGS" count="1000"/>
				</recipe>
				<recipe name="disa25mmGrenadeHE1000" count="1" craft_time="1">
					<ingredient name="disa25mmGrenadeHE" count="1000"/>
				</recipe>
			</append>
		</if>
	</conditional>
</zzzAGF-Compatibilities>
