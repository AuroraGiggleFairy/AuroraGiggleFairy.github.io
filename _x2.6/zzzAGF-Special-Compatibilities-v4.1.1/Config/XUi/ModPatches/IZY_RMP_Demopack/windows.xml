<zzzAGF-Compatibilities>
	<!-- IZY_RMP_Demopack -->
	<conditional>
		<if cond="mod_loaded('AGF-HUDPlus-PurpleBook')">
			<!--All Checklist - Section 11 of Explosives-->
			<append xpath="/windows/window[@name='Schematics']/rect[@name='tabs']/rect[@name='tabsContents']/rect[@name='craftinglistTab']/rect[@name='tabs']/rect[@name='tabsContents']/rect[@name='allChecklists']/rect[@name='checklistExplosives']/rect[12]">
				<sprite name="itemIcon" depth="3" pos="26,-35" size="21,21" foregroundlayer="true" atlas="ItemIconAtlas" sprite="IZYgunT2LGLChinalakeGrenadeLauncher" color="" tooltip_key="IZYgunT2LGLChinalakeGrenadeLauncher"/>
				<sprite name="itemIcon" depth="3" pos="26,-60" size="21,21" foregroundlayer="true" atlas="ItemIconAtlas" sprite="IZYgunT3LGLXM25" color="" tooltip_key="IZYgunT3LGLXM25"/>
				<sprite name="itemIcon" depth="3" pos="26,-85" size="21,21" foregroundlayer="true" atlas="ItemIconAtlas" sprite="IZYgunT3RocketLauncherRPG7" color="" tooltip_key="IZYgunT3RocketLauncherRPG7"/>
			</append>
			<!--Zoomed Checklist - Section 11 of Explosives, is down below due to a positioning change.-->
			<!--All Checklist - AGF's section of IZY's explosive ammo types unlocked at level 50 of explosives-->
			<set xpath="/windows/window[@name='Schematics']/rect[@name='tabs']/rect[@name='tabsContents']/rect[@name='craftinglistTab']/rect[@name='tabs']/rect[@name='tabsContents']/rect[@name='allChecklists']/rect[@name='checklistExplosives']/rect[@name='Section11']/@pos">0,-650</set>
			<insertafter xpath="/windows/window[@name='Schematics']/rect[@name='tabs']/rect[@name='tabsContents']/rect[@name='craftinglistTab']/rect[@name='tabs']/rect[@name='tabsContents']/rect[@name='allChecklists']/rect[@name='checklistExplosives']/rect[11]">
				<rect name="SectionIZYExplosive" pos="0,-540" height="110">
					<!--Background of Section-->
					<sprite depth="1" name="backgroundSection" sprite="menu_empty3px" width="50" height="112" color="[darkGrey]" type="sliced" fillcenter="true"/>
					<sprite depth="2" name="backgroundBorderSection" sprite="menu_empty3px" foregroundlayer="true" pos="0,0" width="50" height="112" color="[black]" type="sliced" fillcenter="false"/>
					<!--If completed-->
					<filledsprite depth="1" name="yesUnlocked" globalopacity="false" color="75,140,75,255" pos="0,0" width="50" height="110" fillcenter="true" type="filled" fill="{cvar(craftingExplosivesCheck50)}"/>
					<!--Q1-->
					<sprite depth="2" name="backgroundBorder" sprite="menu_empty3px" pos="2,-2" width="21" height="18" color="[black]" type="sliced" fillcenter="false"/>
					<sprite depth="2" name="background" sprite="menu_empty3px" pos="3,-3" width="19" height="16" color="156, 136, 103" type="sliced" fillcenter="true"/>
					<label depth="3" name="checkunlock" pos="0,-3" width="25" height="16" justify="center" text="50" color="[black]" font_size="16"/>
					<!--Icons-->
					<sprite name="itemIcon" depth="3" pos="26,-10" size="21,21" foregroundlayer="true" atlas="ItemIconAtlas" sprite="ammo25mmTRAINING" color="" tooltip_key="ammo25mmGrenadeTraining"/>
					<sprite name="itemIcon" depth="3" pos="2,-35" size="21,21" foregroundlayer="true" atlas="ItemIconAtlas" sprite="ammo25mmFRAGS" color="" tooltip_key="ammo25mmGrenadeFRAGS"/>
					<sprite name="itemIcon" depth="3" pos="26,-35" size="21,21" foregroundlayer="true" atlas="ItemIconAtlas" sprite="ammo25mmHE" color="" tooltip_key="ammo25mmGrenadeHE"/>
					<sprite name="itemIcon" depth="3" pos="2,-60" size="21,21" foregroundlayer="true" atlas="ItemIconAtlas" sprite="ammoRocketRPGTraning" color="" tooltip_key="ammoRocketRPGTraning"/>
					<sprite name="itemIcon" depth="3" pos="26,-60" size="21,21" foregroundlayer="true" atlas="ItemIconAtlas" sprite="ammoRocketRPGHE" color="" tooltip_key="ammoRocketRPGHE"/>
					<sprite name="itemIcon" depth="3" pos="2,-85" size="21,21" foregroundlayer="true" atlas="ItemIconAtlas" sprite="ammoRocketRPGIncendiary" color="" tooltip_key="ammoRocketRPGIncendiary"/>
				</rect>
			</insertafter>
			<!--Zoomed In - AGF's section of IZY's explosive ammo types unlocked at level 50 of explosives + Explosives Weapons in final section.-->
			<remove xpath="/windows/window[@name='Schematics']/rect[@name='tabs']/rect[@name='tabsContents']/rect[@name='craftinglistTab']/rect[@name='tabs']/rect[@name='tabsContents']//rect[@name='zoomedExplosives']/grid[@name='checklistExplosives']/entry[6]"/>
			<insertafter xpath="/windows/window[@name='Schematics']/rect[@name='tabs']/rect[@name='tabsContents']/rect[@name='craftinglistTab']/rect[@name='tabs']/rect[@name='tabsContents']//rect[@name='zoomedExplosives']/grid[@name='checklistExplosives']/entry[5]">
				<entry name="QSection">
					<rect pos="3,0">
						<!--Background of Section-->
						<sprite depth="1" name="backgroundSection" sprite="menu_empty3px" width="300" height="100" color="[darkGrey]" type="sliced" fillcenter="true"/>
						<sprite depth="3" name="backgroundBorderSection" sprite="menu_empty3px" foregroundlayer="true" pos="0,0" width="300" height="100" color="[black]" type="sliced" fillcenter="false"/>
						<!--If completed-->
						<filledsprite depth="2" name="yesUnlocked" color="75,140,75,255" pos="0,0" width="300" height="100" fillcenter="true" type="filled" fill="{cvar(craftingExplosivesCheck50)}"/>
						<!--Q1-->
						<sprite depth="3" name="backgroundBorder" sprite="menu_empty3px" pos="0,0" width="50" height="30" color="[black]" type="sliced" fillcenter="false"/>
						<sprite depth="2" name="background" sprite="menu_empty3px" pos="0,0" width="50" height="30" color="156, 136, 103" type="sliced" fillcenter="true"/>
						<label depth="3" name="checkunlock" pos="0,-4" width="50" height="30" justify="center" text="50" color="[black]" font_size="26"/>
						<!--Icons-->
						<sprite name="itemIcon" depth="3" pos="5,-40" size="50,50" foregroundlayer="true" atlas="ItemIconAtlas" sprite="ammo25mmTRAINING" color="" tooltip_key="ammo25mmGrenadeTraining"/>
						<sprite name="itemIcon" depth="3" pos="53,-40" size="50,50" foregroundlayer="true" atlas="ItemIconAtlas" sprite="ammo25mmFRAGS" color="" tooltip_key="ammo25mmGrenadeFRAGS"/>
						<sprite name="itemIcon" depth="3" pos="101,-40" size="50,50" foregroundlayer="true" atlas="ItemIconAtlas" sprite="ammo25mmHE" color="" tooltip_key="ammo25mmGrenadeHE"/>
						<sprite name="itemIcon" depth="3" pos="149,-40" size="50,50" foregroundlayer="true" atlas="ItemIconAtlas" sprite="ammoRocketRPGTraning" color="" tooltip_key="ammoRocketRPGTraning"/>
						<sprite name="itemIcon" depth="3" pos="197,-40" size="50,50" foregroundlayer="true" atlas="ItemIconAtlas" sprite="ammoRocketRPGHE" color="" tooltip_key="ammoRocketRPGHE"/>
						<sprite name="itemIcon" depth="3" pos="245,-40" size="50,50" foregroundlayer="true" atlas="ItemIconAtlas" sprite="ammoRocketRPGIncendiary" color="" tooltip_key="ammoRocketRPGIncendiary"/>
					</rect>
				</entry>
				<entry name="QSection">
					<rect pos="3,0">
						<!--Background of Section-->
						<sprite depth="1" name="backgroundSection" sprite="menu_empty3px" width="300" height="100" color="[darkGrey]" type="sliced" fillcenter="true"/>
						<sprite depth="3" name="backgroundBorderSection" sprite="menu_empty3px" foregroundlayer="true" pos="0,0" width="300" height="100" color="[black]" type="sliced" fillcenter="false"/>
						<!--If completed-->
						<filledsprite depth="2" name="yesUnlocked" color="75,140,75,255" globalopacity="false" pos="0,0" width="50" height="100" fillcenter="true" type="filled" fill="{cvar(craftingExplosivesCheck50)}"/>
						<filledsprite depth="2" name="yesUnlocked" color="75,140,75,255" globalopacity="false" pos="0,0" width="100" height="100" fillcenter="true" type="filled" fill="{cvar(craftingExplosivesCheck60)}"/>
						<filledsprite depth="2" name="yesUnlocked" color="75,140,75,255" globalopacity="false" pos="0,0" width="150" height="100" fillcenter="true" type="filled" fill="{cvar(craftingExplosivesCheck70}"/>
						<filledsprite depth="2" name="yesUnlocked" color="75,140,75,255" globalopacity="false" pos="0,0" width="200" height="100" fillcenter="true" type="filled" fill="{cvar(craftingExplosivesCheck80}"/>
						<filledsprite depth="2" name="yesUnlocked" color="75,140,75,255" globalopacity="false" pos="0,0" width="250" height="100" fillcenter="true" type="filled" fill="{cvar(craftingExplosivesCheck90)}"/>
						<filledsprite depth="2" name="yesUnlocked" color="75,140,75,255" globalopacity="false" pos="0,0" width="300" height="100" fillcenter="true" type="filled" fill="{cvar(craftingExplosivesCheck100)}"/>
						<!--Q1-->
						<sprite depth="3" name="backgroundBorder" sprite="menu_empty3px" pos="0,0" width="50" height="30" color="[black]" type="sliced" fillcenter="false"/>
						<sprite depth="2" name="background" sprite="menu_empty3px" pos="0,0" width="50" height="30" color="156, 136, 103" type="sliced" fillcenter="true"/>
						<label depth="3" name="checkunlock" pos="0,-4" width="50" height="30" justify="center" text="50" color="[black]" font_size="26"/>
						<!--Q2-->
						<sprite depth="3" name="backgroundBorder" sprite="menu_empty3px" pos="50,0" width="50" height="30" color="[black]" type="sliced" fillcenter="false"/>
						<sprite depth="2" name="background" sprite="menu_empty3px" pos="50,0" width="50" height="30" color="207, 119, 41" type="sliced" fillcenter="true"/>
						<label depth="3" name="checkunlock" pos="50,-4" width="50" height="30" justify="center" text="60" color="[black]" font_size="26"/>
						<!--Q3-->
						<sprite depth="3" name="backgroundBorder" sprite="menu_empty3px" pos="100,0" width="50" height="30" color="[black]" type="sliced" fillcenter="false"/>
						<sprite depth="2" name="background" sprite="menu_empty3px" pos="100,0" width="50" height="30" color="162, 164, 19" type="sliced" fillcenter="true"/>
						<label depth="3" name="checkunlock" pos="100,-4" width="50" height="30" justify="center" text="70" color="[black]" font_size="26"/>
						<!--Q4-->
						<sprite depth="3" name="backgroundBorder" sprite="menu_empty3px" pos="150,0" width="50" height="30" color="[black]" type="sliced" fillcenter="false"/>
						<sprite depth="2" name="background" sprite="menu_empty3px" pos="150,0" width="50" height="30" color="50, 194, 52" type="sliced" fillcenter="true"/>
						<label depth="3" name="checkunlock" pos="150,-4" width="50" height="30" justify="center" text="80" color="[black]" font_size="26"/>
						<!--Q5-->
						<sprite depth="3" name="backgroundBorder" sprite="menu_empty3px" pos="200,0" width="50" height="30" color="[black]" type="sliced" fillcenter="false"/>
						<sprite depth="2" name="background" sprite="menu_empty3px" pos="200,0" width="50" height="30" color="49, 93, 206" type="sliced" fillcenter="true"/>
						<label depth="3" name="checkunlock" pos="200,-4" width="50" height="30" justify="center" text="90" color="[black]" font_size="26"/>
						<!--Q6-->
						<sprite depth="3" name="backgroundBorder" sprite="menu_empty3px" pos="250,0" width="50" height="30" color="[black]" type="sliced" fillcenter="false"/>
						<sprite depth="2" name="background" sprite="menu_empty3px" pos="250,0" width="50" height="30" color="164, 42, 204" type="sliced" fillcenter="true"/>
						<label depth="3" name="checkunlock" pos="250,-4" width="50" height="30" justify="center" text="100" color="[black]" font_size="26"/>
						<!--Icons-->
						<sprite name="itemIcon" depth="3" pos="50,-40" size="50,50" foregroundlayer="true" atlas="ItemIconAtlas" sprite="gunExplosivesT3RocketLauncher" color="" tooltip_key="gunExplosivesT3RocketLauncher"/>
						<sprite name="itemIcon" depth="3" pos="100,-40" size="50,50" foregroundlayer="true" atlas="ItemIconAtlas" sprite="IZYgunT2LGLChinalakeGrenadeLauncher" color="" tooltip_key="IZYgunT2LGLChinalakeGrenadeLauncher"/>
						<sprite name="itemIcon" depth="3" pos="150,-40" size="50,50" foregroundlayer="true" atlas="ItemIconAtlas" sprite="IZYgunT3LGLXM25" color="" tooltip_key="IZYgunT3LGLXM25"/>
						<sprite name="itemIcon" depth="3" pos="200,-40" size="50,50" foregroundlayer="true" atlas="ItemIconAtlas" sprite="IZYgunT3RocketLauncherRPG7" color="" tooltip_key="IZYgunT3RocketLauncherRPG7"/>
					</rect>
				</entry>
			</insertafter>
			<set xpath="/windows/window[@name='Schematics']/rect[@name='tabs']/rect[@name='tabsContents']/rect[@name='craftinglistTab']/rect[@name='tabs']/rect[@name='tabsContents']//rect[@name='zoomedExplosives']/grid[@name='checklistExplosives']/@rows">5</set>
			<set xpath="/windows/window[@name='Schematics']/rect[@name='tabs']/rect[@name='tabsContents']/rect[@name='craftinglistTab']/rect[@name='tabs']/rect[@name='tabsContents']//rect[@name='zoomedExplosives']/grid[@name='checklistExplosives']/@pos">545,-185</set>
			<set xpath="/windows/window[@name='Schematics']/rect[@name='tabs']/rect[@name='tabsContents']/rect[@name='craftinglistTab']/rect[@name='tabs']/rect[@name='tabsContents']//rect[@name='zoomedExplosives']/grid[@name='checklistExplosivesTitle']/@pos">245,-260</set>
		</if>
	</conditional>
</zzzAGF-Compatibilities>
