<AGFVanillaPlus-ArmorHarvestMods>


	<append xpath="/ui_display_info/item_display">
		<item_display_info display_type="modFarmer">
			<display_entry name="dLootProb" title_key="statBonusSeeds" display_type="Percent" display_leading_plus="true"/>
			<display_entry name="dHarvestCount" title_key="statCropHarvestCount" display_type="Percent"/>
			<display_entry name="dHarvestCount2" title_key="statSeedHarvestCount" display_type="Percent"/>	
		</item_display_info>
		<item_display_info display_type="modMiner">
			<display_entry name="dHarvestCount" title_key="statOreHarvest" display_type="Percent" display_leading_plus="true"/>
			<display_entry name="dStaminaLoss" title_key="statMiningStaminaLoss" display_type="Percent" negative_preferred="true"/>
			<display_entry name="dBlockDamage" title_key="statOreBlockDamage" display_type="Percent"/>	
		</item_display_info>
		<item_display_info display_type="modScavenger">
			<display_entry name="dPlayerExpGain" title_key="statShowPlayerExpGainScavenger" display_type="Percent" display_leading_plus="true"/>
			<display_entry name="dHarvestSalvage" title_key="statHarvestSalvage" display_type="Percent" display_leading_plus="true"/>
			<display_entry name="dStaminaLoss" title_key="statSalvageStaminaLoss" display_type="Percent" negative_preferred="true"/>
		</item_display_info>
		<item_display_info display_type="modLumberjack">
			<display_entry name="dHarvestCount" title_key="statLumberjackHarvest" display_type="Percent" display_leading_plus="true"/>
			<display_entry name="dStaminaLoss" title_key="statAxeStaminaLoss" display_type="Percent" negative_preferred="true"/>
			<display_entry name="dHarvestCount2" title_key="statAxeHarvest" display_type="Percent"/>	
		</item_display_info>
	</append>


</AGFVanillaPlus-ArmorHarvestMods>