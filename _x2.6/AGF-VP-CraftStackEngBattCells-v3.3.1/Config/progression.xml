<AGFVanillaPlus-CraftStackEngBattCells>


		<!--Removes Car Battery as its own display line-->
		<remove xpath="/progression/crafting_skills/crafting_skill[@name='craftingElectrician']/display_entry[@icon='carBattery']"/>
		
		<!--Adds car battery within the battery bank display-->
		<append xpath="/progression/crafting_skills/crafting_skill[@name='craftingElectrician']/display_entry[@icon='batterybank']/unlock_entry/@item">,carBattery</append>
		

		<!--removes old leveling and tiers of carbattery-->
		<remove xpath="/progression/crafting_skills/crafting_skill[@name='craftingElectrician']/effect_group/passive_effect[@name='CraftingTier']"/>	
		<remove xpath="/progression/crafting_skills/crafting_skill[@name='craftingElectrician']/effect_group/passive_effect[@tags='carBattery']"/>
		
		<!--adds car battery to the level 55 items-->
			<!--Currently my All Doors SETS this and now adds the car battery-->
		<append xpath="/progression/crafting_skills/crafting_skill[@name='craftingElectrician']/effect_group/passive_effect[@level='55,100']/@tags">,carBattery</append>


		<!--adds engine to level 45 items-->
		<append xpath="/progression/crafting_skills/crafting_skill[@name='craftingElectrician']/display_entry[@icon='motionsensor']/unlock_entry/@item">,smallEngine</append>
		<append xpath="/progression/crafting_skills/crafting_skill[@name='craftingElectrician']/effect_group/passive_effect[@level='45,100']/@tags">,smallEngine</append>


		<!--adds Solar Banks and Solar Cells-->
		<insertafter xpath="/progression/crafting_skills/crafting_skill[@name='craftingElectrician']/display_entry[@icon='batterybank']">
			<display_entry icon="solarbank" name_key="electricianAGF" has_quality="false" unlock_level="80,100" >
				<unlock_entry item="solarbank" unlock_tier="1" />
				<unlock_entry item="solarCell" unlock_tier="2" />
			</display_entry>		
		</insertafter>
		
		<append xpath="/progression/crafting_skills/crafting_skill[@name='craftingElectrician']/effect_group">
			<passive_effect name="RecipeTagUnlocked" operation="base_set" level="80,100" value="1" tags="solarbank"/>
			<passive_effect name="RecipeTagUnlocked" operation="base_set" level="100" value="1" tags="solarCell"/>
		</append>

</AGFVanillaPlus-CraftStackEngBattCells>

 