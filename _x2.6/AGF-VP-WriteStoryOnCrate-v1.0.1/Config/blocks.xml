<AGF-WriteStoryOnCrate>


	<append xpath="/blocks">
		<block name="agfMessageCrate">			
			<property name="CustomIcon" value="cntIronWritableCrate"/>
			<property name="CreativeMode" value="Player"/>
			<property name="Class" value="CompositeTileEntity"/>
			<property class="CompositeFeatures">				
				<property class="TEFeatureStorage">
					<property name="LootList" value="agfMessageCrate"/>
				</property>				
			<property class="TEFeatureLockable"/>
				<property class="TEFeatureSignable">
					<property name="FontSize" value="45"/>
					<property name="LineCount" value="8"/>
					<property name="LineWidth" value="0.6"/>
				</property>
			</property>
			<property name="DescriptionKey" value="cntIronWritableCrateDesc"/>
			<property name="Material" value="Mleather"/>
			<property name="Shape" value="ModelEntity"/>
			<property name="Model" value="@:Entities/LootContainers/ironWritableCratePrefab.prefab"/>
			<property name="WaterFlow" value="permitted"/>
			<property name="Path" value="solid"/>
			<property name="Place" value="TowardsPlacerInverted"/>
			<property name="AllowedRotations" value="Basic90"/>
			<property name="FuelValue" value="20"/>
			<property name="EconomicValue" value="6"/>
			<property name="MaxDamage" value="300"/>
			<property name="SoundPickup" value="crateiron_grab"/>
			<property name="SoundPlace" value="crateiron_place"/>
			<property name="DowngradeBlock" value="agfMessageCrateInsecure"/>
			<property class="RepairItems">
				<property name="resourceLeather" value="3"/>
			</property>
			<drop event="Destroy" name="resourceLeather" count="0"/>
			<drop event="Fall" name="agfMessageCrate" count="1" prob="0.75" stick_chance="1"/>
			
			<property name="SortOrder1" value="B106"/>
			<property name="SortOrder2" value="0002"/>
			<property name="Group" value="Building,advBuilding"/>
			<property name="Tags" value="timecharge"/>
			<property name="FilterTags" value="MC_playerBlocks,SC_decor"/>
		</block>
		<block name="agfMessageCrateInsecure">			
			<property name="CustomIcon" value="cntIronWritableCrate"/>
			<property name="CreativeMode" value="None"/>
			<property name="Class" value="CompositeTileEntity"/>
			<property class="CompositeFeatures">				
				<property class="TEFeatureStorage">
					<property name="LootList" value="agfMessageCrate"/>
				</property>				
				<property class="TEFeatureSignable">
					<property name="FontSize" value="45"/>
					<property name="LineCount" value="8"/>
					<property name="LineWidth" value="0.6"/>
				</property>
			</property>
			<property name="DescriptionKey" value="cntIronWritableCrateDesc"/>
			<property name="Material" value="Mleather"/>
			<property name="Shape" value="ModelEntity"/>
			<property name="Model" value="@:Entities/LootContainers/ironWritableCratePrefab.prefab"/>
			<property name="WaterFlow" value="permitted"/>
			<property name="Path" value="solid"/>
			<property name="Place" value="TowardsPlacerInverted"/>
			<property name="AllowedRotations" value="Basic90"/>
			<property name="FuelValue" value="20"/>
			<property name="EconomicValue" value="6"/>
			<property name="MaxDamage" value="300"/>
			<property name="SoundPickup" value="crateiron_grab"/>
			<property name="SoundPlace" value="crateiron_place"/>
			<property class="RepairItems">
				<property name="resourceLeather" value="3"/>
			</property>
			<drop event="Destroy" name="agfMessageCrate" count="1"/>
			<drop event="Fall" name="agfMessageCrate" count="1" prob="0.75" stick_chance="1"/>
			
			<property name="SortOrder1" value="B106"/>
			<property name="SortOrder2" value="0002"/>
			<property name="Group" value="Building,advBuilding"/>
		</block>
	</append>	





</AGF-WriteStoryOnCrate>
