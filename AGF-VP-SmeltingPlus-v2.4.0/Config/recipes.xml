<AGFVanillaPlus-SmeltingPlus>


<!--Sand smelts at same rate as stone and clay for simplicity. 6,000 sand smelts into 30,000 in the forge.-->
<set xpath="/recipes/recipe[@name='resourceCrushedSand']/ingredient[@name='unit_glass']/@count">5</set>


<!--To control the exact amounts of clay, sand, and rocks in the forge... mostly for us OCD people-->
<append xpath="/recipes">
	<recipe name="unit_clay" count="1" material_based="true" craft_area="forge" craft_time="1" craft_exp_gain="0" always_unlocked="true" use_ingredient_modifier="false">
		<ingredient name="unit_clay" count="1"/>
	</recipe>
	<recipe name="unit_glass" count="1" material_based="true" craft_area="forge" craft_time="1" craft_exp_gain="0" always_unlocked="true" use_ingredient_modifier="false">
		<ingredient name="unit_glass" count="1"/>
	</recipe>
	<recipe name="unit_stone" count="1" material_based="true" craft_area="forge" craft_time="1" craft_exp_gain="0" always_unlocked="true" use_ingredient_modifier="false">
		<ingredient name="unit_stone" count="1"/>
	</recipe>
</append>


<!--Advanced Metal Smelting, a stack of 6,000 smelts 1:5 like stone-->
<append xpath="/recipes">
	<!--ADV Iron-->
	<recipe name="resourceScrapIronAdvSmelt" count="6000" craft_time="4" craft_area="workbench" craft_exp_gain="0" tags="learnable,workbenchCrafting">
		<ingredient name="resourceScrapIron" count="30000"/>
	</recipe>
	<recipe name="resourceScrapIronAdvSmelt" count="6000" craft_time="4" craft_area="workbench" craft_exp_gain="0" tags="learnable,workbenchCrafting">
		<ingredient name="resourceScrapIronBundle" count="5"/>
	</recipe>		
	
	<!--ADV Brass-->
	<recipe name="resourceScrapBrassAdvSmelt" count="6000" craft_time="4" craft_area="workbench" craft_exp_gain="0" tags="learnable,workbenchCrafting">
		<ingredient name="resourceScrapBrass" count="30000"/>
	</recipe>
	<recipe name="resourceScrapBrassAdvSmelt" count="6000" craft_time="4" craft_area="workbench" craft_exp_gain="0" tags="learnable,workbenchCrafting">
		<ingredient name="resourceRadiator" count="120"/>
	</recipe>
	<recipe name="resourceScrapBrassAdvSmelt" count="6000" craft_time="4" craft_area="workbench" craft_exp_gain="0" tags="learnable,workbenchCrafting">
		<ingredient name="casinoCoin" count="30000"/>
	</recipe>
	<conditional><!--Only adds this recipe if player has Mining Plus installed.-->
		<if cond="mod_loaded('AGF-V2-VP-MiningPlus')">	
			<recipe name="resourceScrapBrassAdvSmelt" count="6000" craft_time="4" craft_area="workbench" craft_exp_gain="0" tags="learnable,workbenchCrafting">
				<ingredient name="resourceScrapBrassBundle" count="5"/>
			</recipe>	
		</if>		
	</conditional>		
	
	<!--ADV Lead-->
	<recipe name="resourceScrapLeadAdvSmelt" count="6000" craft_time="4" craft_area="workbench" craft_exp_gain="0" tags="learnable,workbenchCrafting">
		<ingredient name="resourceScrapLead" count="30000"/>
	</recipe>
	<recipe name="resourceScrapLeadAdvSmelt" count="6000" craft_time="4" craft_area="workbench" craft_exp_gain="0" tags="learnable,workbenchCrafting">
		<ingredient name="resourceLeadBundle" count="5"/>
	</recipe>	
</append>


	
</AGFVanillaPlus-SmeltingPlus>


